<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Marketing">
    <meta name="theme-color" content="#E60000">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <title>Surtitodo Marketing Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #E60000;
            --secondary: #111111;
            --accent: #FFC300;
            --bg-color: #f4f6f8;
            --card-bg: #ffffff;
            --text-main: #333333;
            --border-radius: 12px;
        }

        body { 
            font-family: 'Poppins', sans-serif; 
            background: var(--bg-color); 
            margin: 0; 
            padding: 20px 20px 120px 20px; 
            color: var(--text-main);
        }

        /* Cabecera */
        .header { 
            background: var(--secondary); 
            color: var(--accent); 
            padding: 25px 20px; 
            border-radius: var(--border-radius); 
            text-align: center; 
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .header h1 { margin: 0; font-weight: 800; letter-spacing: -0.5px; }
        .header p { margin: 5px 0 0 0; color: #dddddd; font-weight: 500; }

        /* Tarjetas de Configuración */
        .config-layout {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .config-card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 6px rgba(0,0,0,0.04);
            border: 1px solid #eaeaea;
        }

        .config-card h2 {
            font-size: 16px;
            margin: 0 0 15px 0;
            color: var(--secondary);
            border-bottom: 2px solid #f0f0f0;
            padding-bottom: 10px;
        }

        .form-group { margin-bottom: 15px; }
        .form-group:last-child { margin-bottom: 0; }

        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #555;
        }

        select, input[type="text"] {
            width: 100%;
            padding: 12px;
            font-size: 14px;
            border-radius: 8px;
            font-family: 'Poppins', sans-serif;
            border: 1px solid #ddd;
            background: #fdfdfd;
            box-sizing: border-box;
            outline: none;
            transition: border-color 0.2s;
        }

        select:focus, input[type="text"]:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(230,0,0,0.1);
        }

        /* Pestañas y Buscador */
        .inventory-header {
            background: var(--card-bg);
            padding: 20px;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 6px rgba(0,0,0,0.04);
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .tabs { display: flex; gap: 10px; }
        
        .tabs button { 
            background: #f0f0f0; 
            border: none; 
            padding: 10px 20px; 
            font-size: 15px; 
            border-radius: 8px; 
            cursor: pointer; 
            font-family: 'Poppins', sans-serif; 
            font-weight: 600; 
            transition: all 0.2s ease;
            color: #666;
        }
        
        .tabs button.active { 
            background: var(--primary); 
            color: white; 
            box-shadow: 0 4px 10px rgba(230,0,0,0.2);
        }

        .search-box { 
            flex: 1; 
            min-width: 250px; 
            max-width: 400px;
            border: 2px solid #ddd;
            padding: 12px 15px;
            font-size: 15px;
        }

        /* Grilla de Productos */
        .grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
            gap: 20px; 
        }

        .card { 
            background: white; 
            padding: 15px; 
            border-radius: var(--border-radius); 
            box-shadow: 0 2px 8px rgba(0,0,0,0.06); 
            text-align: center; 
            cursor: pointer; 
            border: 3px solid transparent; 
            transition: all 0.2s ease; 
            position: relative;
        }

        .card:hover { 
            transform: translateY(-5px); 
            box-shadow: 0 8px 15px rgba(0,0,0,0.1); 
        }

        .card.selected { 
            border-color: var(--primary); 
            background: #fffafa; 
        }

        .card img { 
            width: 120px; 
            height: 120px; 
            object-fit: contain; 
            margin-bottom: 12px; 
        }

        .card h3 { 
            font-size: 14px; 
            margin: 0 0 8px 0; 
            color: #333; 
            line-height: 1.3;
        }

        .badge-promo { 
            position: absolute; 
            top: -10px; 
            right: -10px; 
            background: var(--accent); 
            color: var(--secondary); 
            padding: 6px 12px; 
            border-radius: 20px; 
            font-size: 13px; 
            font-weight: 800; 
            box-shadow: 0 4px 8px rgba(0,0,0,0.15); 
        }

        .btn-cargar-mas { 
            display: none; 
            margin: 40px auto; 
            background: var(--secondary); 
            color: white; 
            border: none; 
            padding: 12px 30px; 
            border-radius: 50px; 
            font-size: 16px; 
            font-weight: 600; 
            cursor: pointer; 
            font-family: 'Poppins', sans-serif; 
            transition: 0.2s; 
        }

        .btn-cargar-mas:hover { 
            background: #333; 
            transform: scale(1.02); 
        }

        /* Barra de Acción Inferior Fija */
        .bottom-action-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
            padding: 15px 30px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            z-index: 100;
            box-sizing: border-box;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            transform: translateY(100%);
        }

        .bottom-action-bar.visible {
            transform: translateY(0);
        }

        .action-group {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #f8f9fa;
            padding: 10px;
            border-radius: 50px;
            border: 1px solid #eaeaea;
        }

        .btn-action {
            border: none; 
            padding: 12px 25px; 
            border-radius: 50px; 
            font-size: 16px; 
            font-weight: 700; 
            cursor: pointer; 
            font-family: 'Poppins', sans-serif; 
            transition: all 0.2s ease;
        }

        .btn-primary { background: var(--primary); color: white; box-shadow: 0 4px 15px rgba(230,0,0,0.3); }
        .btn-primary:hover { background: #cc0000; transform: translateY(-2px); }
        
        .btn-dark { background: var(--secondary); color: var(--accent); box-shadow: 0 4px 15px rgba(0,0,0,0.2); }
        .btn-dark:hover { background: #000; transform: translateY(-2px); }

        #cargando-video {
            font-weight: 600; 
            color: var(--primary); 
            font-size: 14px; 
            background: #fff0f0;
            padding: 10px 20px;
            border-radius: 50px;
            display: none;
        }

        /* Modal */
        .modal { 
            display: none; 
            position: fixed; 
            top: 0; left: 0; 
            width: 100%; height: 100%; 
            background: rgba(0,0,0,0.85); 
            justify-content: center; 
            align-items: center; 
            z-index: 1000; 
            backdrop-filter: blur(5px);
        }

        .modal-content { 
            background: white; 
            padding: 30px; 
            border-radius: var(--border-radius); 
            text-align: center; 
            max-height: 90vh; 
            display: flex; 
            flex-direction: column; 
            max-width: 600px;
            width: 90%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .modal-content img { 
            max-height: 50vh; 
            object-fit: contain; 
            margin-bottom: 20px; 
            border-radius: 8px; 
            border: 1px solid #eee; 
        }

        /* --- MODO OSCURO --- */

        body.dark-theme div[id="contenedor-cliente-oferta"] {
            background: #2a2010 !important;
            border-color: #554422 !important;
        }
        body.dark-theme div[id="contenedor-tutorial"] {
            background: #2a2a2a !important;
            border-color: #444 !important;
        }

        body.dark-theme {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-main: #e0e0e0;
            --secondary: #000000;
        }

        body.dark-theme .config-card,
        body.dark-theme .inventory-header,
        body.dark-theme .modal-content {
            border-color: #333;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        body.dark-theme .bottom-action-bar {
            background: rgba(30, 30, 30, 0.95);
            border-top: 1px solid #333;
        }

        body.dark-theme input[type="text"], 
        body.dark-theme select, 
        body.dark-theme textarea {
            background: #2a2a2a;
            color: #e0e0e0;
            border-color: #444;
        }

        body.dark-theme .tabs button { background: #333; color: #aaa; }
        body.dark-theme .tabs button.active { background: var(--primary); color: white; }
        
        body.dark-theme .card { border-color: #333; background: #1e1e1e; }
        body.dark-theme .card h3 { color: #e0e0e0; }
        body.dark-theme .card.selected { background: #2a1111; border-color: var(--primary); }
        
        body.dark-theme .action-group { background: #2a2a2a; border-color: #444; }
        
        body.dark-theme .modal-content div[style*="background: #f8f9fa"] {
            background: #2a2a2a !important;
            border-color: #444 !important;
        }

        body.dark-theme .config-card h2 {
            color: #ffffff;
            border-bottom-color: #444; 
        }

        body.dark-theme .form-group label {
            color: #e0e0e0; 
        }

        /* --- iPad / móvil --- */
        .network-banner {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: #a8dadc;
            padding: 12px 16px;
            border-radius: var(--border-radius);
            margin-bottom: 20px;
            font-size: 13px;
            line-height: 1.5;
            border: 1px solid #2a3a5c;
        }

        .network-banner strong { color: #f1faee; }
        .network-banner code {
            background: rgba(255,255,255,0.1);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 12px;
            word-break: break-all;
        }

        .ios-hint {
            display: none;
            background: #fff8e6;
            border: 1px solid #ffd666;
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 12px;
            color: #664d03;
            margin-top: 10px;
            text-align: left;
            line-height: 1.4;
        }

        .ios-hint.visible { display: block; }

        .loading-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.75);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(4px);
        }

        .loading-overlay.visible { display: flex; }

        .loading-box {
            background: white;
            padding: 30px 40px;
            border-radius: 16px;
            text-align: center;
            max-width: 320px;
            width: 90%;
        }

        .loading-spinner {
            width: 48px;
            height: 48px;
            border: 4px solid #f0f0f0;
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 16px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .progress-bar-wrap {
            width: 100%;
            height: 8px;
            background: #eee;
            border-radius: 4px;
            margin: 16px 0 8px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary), #ff4444);
            border-radius: 4px;
            transition: width 0.4s ease;
        }

        #loading-porcentaje {
            font-size: 13px;
            color: var(--primary);
            font-weight: 700;
            margin: 0;
        }

        .modal-content video {
            width: 100%;
            max-height: 50vh;
            border-radius: 8px;
            margin-bottom: 16px;
            background: #000;
        }

        .modal-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-bottom: 16px;
        }

        @media (max-width: 900px) {
            body { padding: 12px 12px 140px 12px; }

            .header { padding: 20px 16px; }
            .header h1 { font-size: 1.25rem; }

            .config-layout {
                grid-template-columns: 1fr;
            }

            .inventory-header {
                flex-direction: column;
                align-items: stretch;
            }

            .tabs {
                flex-wrap: wrap;
            }

            .tabs button {
                flex: 1;
                min-width: calc(50% - 5px);
                padding: 12px 10px;
                font-size: 13px;
            }

            .search-box {
                min-width: 100% !important;
                max-width: 100%;
            }

            .grid {
                grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
                gap: 12px;
            }

            .card { padding: 10px; }
            .card img { width: 90px; height: 90px; }

            .bottom-action-bar {
                flex-direction: column;
                padding: 12px 16px;
                gap: 10px;
            }

            .action-group {
                flex-direction: column;
                width: 100%;
                border-radius: 12px;
                padding: 12px;
            }

            .action-group select {
                width: 100% !important;
                min-width: unset !important;
            }

            .btn-action {
                width: 100%;
                padding: 14px 20px;
                font-size: 15px;
            }

            #btn-generar { width: 100%; }

            .modal-content {
                padding: 20px;
                max-height: 95vh;
                overflow-y: auto;
            }
        }

        @media (hover: none) {
            .card:hover { transform: none; }
            .btn-primary:hover, .btn-dark:hover { transform: none; }
        }
    </style>
</head>
<body>

    <div class="header" style="position: relative;">
        <button id="theme-toggle" onclick="toggleTheme()" style="position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.1); border: none; font-size: 20px; cursor: pointer; padding: 10px; border-radius: 50%; transition: 0.3s;" title="Cambiar tema">
            🌙
        </button>
        
        <h1>⚙️ Panel de Marketing Surtitodo</h1>
        <p>Generador Automático de Contenido Digital</p>
    </div>

    <div id="network-banner" class="network-banner" style="display: none;">
        <strong>📱 Acceso desde iPad:</strong> Conecta tu iPad a la misma WiFi y abre Safari en<br>
        <code id="ipad-url">cargando...</code>
    </div>

    <div class="config-layout">
        
        <div class="config-card">
            <h2>🎨 1. Estilo y Formato</h2>
            
            <div class="form-group">
                <label>Formato (Cantidad de Productos):</label>
                <select id="selector-plantilla" onchange="cambiarLimitePlantilla()">
                    <option value="4">Grid 4 Productos</option>
                    <option value="2">Grid 2 Productos</option>
                    <option value="1">1 Producto Destacado</option>
                </select>
            </div>

            <div class="form-group">
                <label>Línea Gráfica (Estilo):</label>
                <select id="selector-tema">
                    <option value="clasico">🔴 Clásico Surtitodo</option>
                    <option value="carnaval">🥳 ¡Gran Carnaval!</option>
                    <option value="vip">⚫ VIP Premium</option>
                    <option value="fruver">🟢 Frescura Natural</option>
                    <option value="mercado">🍅 Estilo Mercado</option>
                    <option value="ecommerce">🛒 Exclusivo Web</option>
                    <option value="sorpresa">😱 Precios de Locura</option>
                    <option value="lanzamiento">✨ Nuevo Ingreso (Estreno)</option>
                    <option value="comunicado">📢 Comunicado (Cierre 3 de Abril)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Tamaño del Lienzo:</label>
                <select id="selector-orientacion">
                    <option value="feed">Post Cuadrado (1080x1350)</option>
                    <option value="historia">Historia / Estado (1080x1920)</option>
                </select>
            </div>
        </div>

        <div class="config-card">
            <h2>📝 2. Textos Publicitarios</h2>
            
            <div class="form-group">
                <label>Título Principal:</label>
                <select id="selector-titulo" onchange="verificarTituloManual(); onTituloCampanaCambio();">
                    <option value="Dias De Ahorro">Dias De Ahorro</option>
                    <option value="Gran Madrugón">Gran Madrugón</option>
                    <option value="Quincena de Ofertas">Quincena de Ofertas</option>
                    <option value="Especial de Carnes">Especial de Carnes</option>
                    <option value="Cyber Surtitodo">Cyber Surtitodo</option>
                    <option value="PERSONALIZADO">✏️ Escribir mi propio título...</option>
                </select>
                <input type="text" id="input-titulo-manual" placeholder="Ej: Feliz Día Mamá" style="display: none; margin-top: 10px;" oninput="onTituloCampanaCambio()">
                <div class="form-group">
                    <label>Etiqueta Promocional (Tagline):</label>
                    <select id="selector-tagline">
                        <option value="Solo por tiempo limitado">Solo por tiempo limitado</option>
                        <option value="¡Aprovecha hoy mismo!">¡Aprovecha hoy mismo!</option>
                        <option value="Precios imbatibles">Precios imbatibles</option>
                        <option value="Exclusivo Web">Exclusivo Web</option>
                        <option value="AVISO IMPORTANTE">AVISO IMPORTANTE</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="config-card" id="card-tier4">
            <h2>🚀 Extras (modo gratuito)</h2>
            <p id="tier4-status" style="font-size: 12px; color: #666; margin: 0 0 12px; line-height: 1.4;">
                Cargando estado...
            </p>

            <div class="form-group">
                <label>Código QR en volante:</label>
                <select id="selector-qr" onchange="toggleQrPersonalizado()">
                    <option value="ninguno">Sin QR</option>
                    <option value="web">Web surtitodoideal.com</option>
                    <option value="whatsapp">WhatsApp pedidos</option>
                    <option value="personalizado">URL personalizada</option>
                </select>
                <input type="text" id="input-qr-url" placeholder="https://..." style="display: none; margin-top: 10px;">
            </div>

            <div class="form-group" style="margin-top: 12px;">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input type="checkbox" id="chk-usar-ia" checked>
                    Mejorar copy con Gemini (capa gratuita, sin tarjeta)
                </label>
            </div>

            <div class="form-group" style="margin-top: 8px;">
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                    <input type="checkbox" id="chk-voz-reel" onchange="toggleGuionVoz()">
                    Narración automática en reel (Edge TTS, 100% gratis)
                </label>

                <div id="contenedor-voz-opciones" style="display: none; margin-top: 10px;">
                    <div class="form-group" style="margin-bottom: 10px;">
                        <label style="font-size: 13px; font-weight: 600;">Tipo de voz:</label>
                        <select id="selector-voz" style="width: 100%; margin-top: 6px; padding: 8px; border-radius: 6px; border: 1px solid #ccc; font-size: 13px;">
                            <option value="es-CO-GonzaloNeural">Hombre · Colombiano (Gonzalo) — Profesional</option>
                            <option value="es-CO-SalomeNeural">Mujer · Colombiana (Salome) — Cercana</option>
                            <option value="es-MX-JorgeNeural">Hombre · Neutro latino (Jorge)</option>
                            <option value="es-ES-AlvaroNeural">Hombre · Formal (Álvaro) — Corporativo</option>
                        </select>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; gap: 8px; flex-wrap: wrap;">
                        <label style="font-size: 13px; font-weight: 600; margin: 0;">Guion de voz:</label>
                        <button type="button" id="btn-regenerar-guion" class="btn-action btn-dark" style="padding: 6px 10px; font-size: 12px;" onclick="regenerarGuionDesdeProductos()">
                            🔄 Regenerar desde productos
                        </button>
                    </div>
                    <p style="font-size: 11px; color: #888; margin: 0 0 8px; line-height: 1.4;">
                        Se crea solo con los productos seleccionados. Puedes editarlo libremente antes de generar el reel.
                    </p>
                    <textarea id="guion-voz-manual" placeholder="Selecciona productos para generar el guion automáticamente..." oninput="onGuionEditadoPorUsuario()" style="width: 100%; min-height: 80px; padding: 10px; border-radius: 6px; border: 1px solid #ccc; font-size: 13px; resize: vertical;"></textarea>

                    <div id="guion-contador" style="font-size: 12px; color: #666; margin-top: 8px; line-height: 1.5; padding: 10px; background: #f8f9fa; border-radius: 6px; border: 1px solid #eaeaea;">
                        Selecciona productos y plantilla de video para ver la guía de palabras.
                    </div>
                </div>
            </div>
        </div>

        <div class="config-card" id="card-limpieza">
            <h2>🧹 Liberar espacio en la Mac</h2>
            <p style="font-size: 12px; color: #666; margin: 0 0 12px; line-height: 1.4;">
                Elimina reels, voces en off y fotos temporales generadas por la app.
                <strong>No borra</strong> música, tutorial base ni assets necesarios para crear contenido.
            </p>
            <div id="limpieza-resumen" style="font-size: 13px; color: #444; margin-bottom: 12px; padding: 12px; background: #f8f9fa; border-radius: 8px; border: 1px solid #eaeaea; line-height: 1.6;">
                Calculando espacio usado...
            </div>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                <button type="button" class="btn-action btn-dark" style="flex: 1; min-width: 140px; padding: 10px; font-size: 13px;" onclick="actualizarResumenLimpieza()">
                    🔄 Actualizar
                </button>
                <button type="button" id="btn-limpiar-archivos" class="btn-action" style="flex: 1; min-width: 140px; padding: 10px; font-size: 13px; background: #c0392b; color: #fff;" onclick="ejecutarLimpieza()">
                    🗑️ Liberar espacio
                </button>
            </div>
        </div>

        <div class="config-card">
            <h2>🎬 3. Videos Especiales</h2>
            
            <div class="form-group">
                <label>Selecciona el tipo de video a generar:</label>
                <select id="selector-video-especial" onchange="cambiarVideoEspecial()">
                    <option value="tutorial">📱 Video Tutorial Automático</option>
                    <option value="cliente_oferta">🎉 Reel: Oferta Ganada (Cliente)</option>
                </select>
            </div>

            <div id="contenedor-tutorial" style="display: block; margin-top: 15px; padding: 15px; background: #fdfdfd; border-radius: 8px; border: 1px solid #eaeaea;">
                <p style="font-size: 13px; color: #666; margin-top: 0; line-height: 1.4;">
                    Genera un Reel automático enseñando a los clientes cómo usar Surtitodo Ideal, usando la grabación base que ya está en el sistema.
                </p>
                <button id="btn-tutorial" class="btn-action btn-dark" style="width: 100%; margin-top: 10px; padding: 12px; font-size: 14px;" onclick="generarTutorial()">
                    ✨ Generar Reel Tutorial
                </button>
            </div>

            <div id="contenedor-cliente-oferta" style="display: none; margin-top: 15px; padding: 15px; background: #fffcf0; border-radius: 8px; border: 1px solid #ffeeba; border-left: 4px solid #FFC300;">
                <p style="font-size: 13px; color: #666; margin-top: 0; line-height: 1.4; margin-bottom: 15px;">
                    Sube la foto de tu cliente y sus datos para crear un Reel de celebración "Nivel Pro".
                </p>
                
                <form id="form-reel-cliente" style="display: flex; flex-direction: column; gap: 12px;">
                    <div>
                        <input type="text" id="clientName" name="clientName" placeholder="👤 Nombre (Ej. Juan Pérez)" required 
                               style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc; font-size: 13px;">
                    </div>
            
                    <div>
                        <input type="text" id="propertyAddress" name="propertyAddress" placeholder="📍 Mensaje o Dirección" required 
                               style="width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #ccc; font-size: 13px;">
                    </div>
            
                    <div>
                        <label style="font-size: 12px; font-weight: 600; color: #555; margin-bottom: 5px; display: block;">📸 Foto del Cliente:</label>
                        <input type="file" id="clientFoto" name="clientFoto" accept="image/png, image/jpeg, image/jpg" required
                               style="width: 100%; padding: 8px; background: #fff; border-radius: 6px; border: 1px solid #ccc; font-size: 12px;">
                    </div>
            
                    <button type="button" id="btn-reel-cliente" onclick="generarReelCliente()" class="btn-action btn-primary"
                            style="width: 100%; margin-top: 5px; padding: 12px; font-size: 14px;">
                        🎬 Generar Reel Pro
                    </button>
                </form>
            </div>
        </div>

    </div>
    
    <div class="inventory-header">
        <div class="tabs">
            <button id="tab-ofertas" class="active" onclick="cambiarPestana('ofertas')">🔥 Ofertas Activas</button>
            <button id="tab-todos" onclick="cambiarPestana('todos')">🛒 Todo el Catálogo</button>
            <button id="tab-estancados" onclick="cambiarPestana('estancados')" style="color: #e11d48; background: #ffe4e6; border: 1px solid #fda4af;">⚠️ Zona de Remate</button>
        </div>
        
        <div style="display: flex; gap: 10px; flex: 1; min-width: 250px; justify-content: flex-end; flex-wrap: wrap;">
            <select id="filtro-linea" class="search-box" style="flex: 1; min-width: 150px; cursor: pointer; padding: 12px; font-family: 'Poppins', sans-serif;" onchange="reiniciarYRenderizar()">
                <option value="">🛒 Todas las Líneas</option>
            </select>
            <input type="text" id="buscador" class="search-box" style="flex: 2; min-width: 200px;" placeholder="🔍 Buscar producto por nombre..." oninput="reiniciarYRenderizar()">
        </div>
    </div>

    <div id="grid-productos" class="grid">
        <p style="grid-column: 1/-1; text-align: center; color: #666; padding: 40px;">Cargando inventario desde el servidor Surtitodo...</p>
    </div>

    <button id="btn-cargar-mas" class="btn-cargar-mas" onclick="cargarMas()">⬇️ Cargar 50 productos más</button>

    <div id="action-container" class="bottom-action-bar">
        
        <div id="cargando-video">
            ⏳ Renderizando a 60fps...
        </div>

        <div class="action-group">
            <select id="selector-plantilla-video" onchange="actualizarContadorGuion(); generarGuionDesdeProductos();" style="border: none; background: transparent; padding: 8px; font-weight: 600; width: auto; min-width: 200px;">
                <option value="PromoReel">💥 Video: Explosivo</option>
                <option value="ReelElegante">✨ Video: Elegante</option>
                <option value="ReelBrutalismo">🚧 Reel Brutalista (Impacto)</option>
                <option value="ReelLanzamiento">🚀 Reel: Nuevo Lanzamiento (Cyber)</option>
                <option value="ReelAraStyle">🛒 Reel Impacto (1 Producto Máximo)</option>
                <option value="ReelTemporada">🌟 Reel: Especial de Temporada</option>
                <option value="ReelCinematico">🎥 Reel Cinemático (Oferta 3D)</option>
                <option value="ReelCarnaval">🍉 Reel: Carnaval Frutas y Verduras</option> </select>
            <button id="btn-generar-video" class="btn-action btn-dark" onclick="generarVideoRemotion()">
                🎬 Crear Reel
            </button>
        </div>

        <button id="btn-generar" class="btn-action btn-primary" onclick="generarVolante()">
            Generar Volante (0)
        </button>
    </div>

    <div id="modal-resultado" class="modal">
        <div class="modal-content">
            <h2 style="margin-top: 0; color: var(--secondary);">¡Diseño Listo! 🎉</h2>
            <img id="imagen-resultado" src="" alt="Volante">
            
            <div style="display: flex; gap: 10px; justify-content: center; margin-bottom: 10px; flex-wrap: wrap;">
                <a id="btn-descargar" class="btn-action btn-primary" style="text-decoration: none; display: inline-block;" href="#" download="volante.png">⬇️ Descargar Imagen</a>
                <button id="btn-compartir-imagen" class="btn-action btn-dark" style="display: none;" onclick="compartirImagen()">📤 Guardar en iPad</button>
                <button class="btn-action" style="background: #e0e0e0; color: #333;" onclick="cerrarModal()">Cerrar</button>
            </div>
            <div id="hint-imagen-ios" class="ios-hint">
                💡 En iPad: también puedes <strong>mantener pulsada</strong> la imagen y elegir <strong>"Guardar en Fotos"</strong>.
            </div>
            
            <div style="text-align: left; background: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px dashed #ccc;">
                <h3 style="margin: 0 0 10px 0; font-size: 14px; color: #555;">📝 Copy para Redes Sociales:</h3>
                <textarea id="texto-copy" readonly style="width: 100%; height: 120px; padding: 10px; border-radius: 5px; border: 1px solid #ddd; resize: none; font-size: 13px;"></textarea>
                <button onclick="copiarCopy()" class="btn-action btn-dark" style="width: 100%; margin-top: 10px; padding: 10px; font-size: 14px;">📋 Copiar Texto</button>
            </div>
        </div>
    </div>

    <div id="modal-video" class="modal">
        <div class="modal-content">
            <h2 style="margin-top: 0; color: var(--secondary);">¡Reel Listo! 🎬</h2>
            <video id="video-resultado" controls playsinline></video>
            <div class="modal-actions">
                <button id="btn-compartir-video" class="btn-action btn-primary" onclick="compartirVideo()">📤 Guardar en iPad</button>
                <a id="btn-descargar-video" class="btn-action btn-dark" style="text-decoration: none; display: inline-block;" href="#" download="reel.mp4">⬇️ Descargar</a>
                <button class="btn-action" style="background: #e0e0e0; color: #333;" onclick="cerrarModalVideo()">Cerrar</button>
            </div>
            <div id="hint-video-ios" class="ios-hint visible">
                💡 En iPad: pulsa <strong>"Guardar en iPad"</strong> para enviarlo a Fotos o Archivos. También puedes mantener pulsado el video → <strong>Compartir</strong>.
            </div>
        </div>
    </div>

    <div id="loading-overlay" class="loading-overlay">
        <div class="loading-box">
            <div class="loading-spinner"></div>
            <p id="loading-text" style="margin: 0; font-weight: 600; color: #333;">Renderizando video...</p>
            <div class="progress-bar-wrap">
                <div id="loading-progress" class="progress-bar-fill"></div>
            </div>
            <p id="loading-porcentaje">0%</p>
            <p id="loading-hint" style="margin: 10px 0 0; font-size: 12px; color: #888;">La Mac hace el trabajo pesado. La 1ª vez puede tardar 2-3 min.</p>
        </div>
    </div>

    <script>
        const esDispositivoIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
        let urlImagenActual = null;
        let urlVideoActual = null;
        let blobImagenActual = null;
        let blobVideoActual = null;
        let inventarioGlobal = [];
        let idsSeleccionados = [];
        let pestanaActual = 'ofertas';
        let paginaActual = 1;
        const PRODUCTOS_POR_PAGINA = 50;
        let limiteProductos = 4;
        let inventarioEstancados = [];
        let intervaloProgreso = null;
        let guionEditadoPorUsuario = false;

        function mostrarCarga(mensaje) {
            document.getElementById('loading-text').innerText = mensaje || 'Renderizando video...';
            document.getElementById('loading-progress').style.width = '0%';
            document.getElementById('loading-porcentaje').innerText = '0%';
            document.getElementById('loading-overlay').classList.add('visible');

            if (intervaloProgreso) clearInterval(intervaloProgreso);
            intervaloProgreso = setInterval(async () => {
                try {
                    const res = await fetch('/api/render-progress');
                    const data = await res.json();
                    if (data.mensaje) {
                        document.getElementById('loading-text').innerText = data.mensaje;
                    }
                    if (data.porcentaje > 0) {
                        document.getElementById('loading-progress').style.width = data.porcentaje + '%';
                        document.getElementById('loading-porcentaje').innerText = data.porcentaje + '%';
                    }
                } catch (e) { /* silencioso */ }
            }, 1500);
        }

        function ocultarCarga() {
            if (intervaloProgreso) {
                clearInterval(intervaloProgreso);
                intervaloProgreso = null;
            }
            document.getElementById('loading-overlay').classList.remove('visible');
        }

        async function cargarInfoServidor() {
            try {
                const res = await fetch('/api/server-info');
                const info = await res.json();
                const esLocalhost = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
                const banner = document.getElementById('network-banner');
                const ipadUrl = document.getElementById('ipad-url');

                if (esLocalhost && info.localIPs && info.localIPs.length > 0) {
                    const url = `http://${info.localIPs[0]}:${info.port}`;
                    ipadUrl.textContent = url;
                    banner.style.display = 'block';
                } else if (!esLocalhost) {
                    ipadUrl.textContent = info.baseUrl;
                    banner.innerHTML = '<strong>✅ Conectado desde red local</strong> — ' + info.baseUrl;
                    banner.style.display = 'block';
                }

                if (esDispositivoIOS) {
                    document.getElementById('btn-compartir-imagen').style.display = 'inline-block';
                    document.getElementById('hint-imagen-ios').classList.add('visible');
                }
            } catch (e) {
                console.warn('No se pudo cargar info del servidor');
            }
        }

        async function mostrarVideo(url, nombreArchivo) {
            urlVideoActual = url;
            const res = await fetch(url);
            if (!res.ok) {
                throw new Error('No se pudo cargar el video del servidor (archivo no encontrado)');
            }

            const contentType = res.headers.get('content-type') || '';
            blobVideoActual = await res.blob();

            if (blobVideoActual.size < 10000 || contentType.includes('text/html') || contentType.includes('application/json')) {
                throw new Error('El servidor no devolvió un video válido. Revisa la consola de la Mac.');
            }

            const blobUrl = URL.createObjectURL(blobVideoActual);
            const video = document.getElementById('video-resultado');
            video.src = blobUrl;

            document.getElementById('btn-descargar-video').href = blobUrl;
            document.getElementById('btn-descargar-video').download = nombreArchivo || 'reel_surtitodo.mp4';

            document.getElementById('modal-video').style.display = 'flex';
        }

        function cerrarModalVideo() {
            document.getElementById('modal-video').style.display = 'none';
            const video = document.getElementById('video-resultado');
            video.pause();
            if (video.src && video.src.startsWith('blob:')) {
                URL.revokeObjectURL(video.src);
            }
            video.removeAttribute('src');
            video.load();
            blobVideoActual = null;
        }

        async function compartirVideo() {
            if (!blobVideoActual && urlVideoActual) {
                try {
                    const res = await fetch(urlVideoActual);
                    blobVideoActual = await res.blob();
                } catch (e) {
                    alert('No se pudo preparar el video. Intenta abrirlo en una nueva pestaña.');
                    return;
                }
            }
            if (!blobVideoActual) return;

            const nombre = document.getElementById('btn-descargar-video').download || 'reel_surtitodo.mp4';
            const file = new File([blobVideoActual], nombre, { type: 'video/mp4' });

            if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
                try {
                    await navigator.share({ files: [file], title: 'Reel Surtitodo' });
                    return;
                } catch (e) {
                    if (e.name !== 'AbortError') console.warn(e);
                }
            }

            const link = document.createElement('a');
            link.href = URL.createObjectURL(blobVideoActual);
            link.download = nombre;
            link.click();
            alert('💡 Mantén pulsado el video de arriba y elige "Compartir" → "Guardar video" para guardarlo en Fotos.');
        }

        async function compartirImagen() {
            if (!blobImagenActual) return;
            const nombre = document.getElementById('btn-descargar').download || 'volante.png';
            const file = new File([blobImagenActual], nombre, { type: 'image/png' });

            if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
                try {
                    await navigator.share({ files: [file], title: 'Volante Surtitodo' });
                    return;
                } catch (e) {
                    if (e.name !== 'AbortError') console.warn(e);
                }
            }

            alert('💡 Mantén pulsada la imagen y elige "Guardar en Fotos".');
        }

        function poblarLineas() {
            const selectLinea = document.getElementById('filtro-linea');
            
            // Extraer líneas únicas y eliminar valores nulos o vacíos
            const lineasUnicas = [...new Set(inventarioGlobal.map(p => p.linea_nombre).filter(Boolean))].sort();
            
            // Reiniciar el select
            selectLinea.innerHTML = '<option value="">🛒 Todas las Líneas</option>';
            
            // Llenar con las opciones
            lineasUnicas.forEach(linea => {
                const option = document.createElement('option');
                option.value = linea;
                // Capitalizar para que se vea estético en el panel
                option.textContent = linea.charAt(0).toUpperCase() + linea.slice(1).toLowerCase();
                selectLinea.appendChild(option);
            });
        }

        async function cargarDatos() {
            try {
                const res = await fetch('/api/local-products'); 
                const data = await res.json();
                inventarioGlobal = data.filter(p => p.proimagenurl && p.precio_venta_final > 0 && !p.oculto);
                poblarLineas();
                renderizarGrilla();
            } catch (error) {
                document.getElementById('grid-productos').innerHTML = '<p style="color:red; grid-column: 1/-1; text-align: center;">Error conectando a la API.</p>';
            }
        }

        async function cambiarPestana(pestana) {
            pestanaActual = pestana;
            
            // Gestión visual de los botones
            document.getElementById('tab-ofertas').classList.toggle('active', pestana === 'ofertas');
            document.getElementById('tab-todos').classList.toggle('active', pestana === 'todos');
            
            // Manejo especial visual para el botón de remate
            const btnEstancados = document.getElementById('tab-estancados');
            if (pestana === 'estancados') {
                btnEstancados.style.background = '#e11d48';
                btnEstancados.style.color = 'white';
                
                // Descargamos los datos si aún no lo hemos hecho
                if (inventarioEstancados.length === 0) {
                    document.getElementById('grid-productos').innerHTML = '<p style="grid-column: 1/-1; text-align: center; color: #e11d48;">⏳ Buscando inventario inmovilizado...</p>';
                    try {
                        const res = await fetch('/api/local-estancados');
                        inventarioEstancados = await res.json();
                    } catch (error) {
                        console.error("Error trayendo estancados");
                    }
                }
            } else {
                btnEstancados.style.background = '#ffe4e6';
                btnEstancados.style.color = '#e11d48';
            }
        
            reiniciarYRenderizar();
        }

        function reiniciarYRenderizar() {
            paginaActual = 1;
            renderizarGrilla();
        }

        function cargarMas() {
            paginaActual++;
            renderizarGrilla();
        }

        function renderizarGrilla() {
            const grid = document.getElementById('grid-productos');
            const busqueda = document.getElementById('buscador').value.toLowerCase();
            
            // 🚨 AQUÍ ESTABA EL DETALLE: Faltaba capturar el valor del select
            const elementoFiltro = document.getElementById('filtro-linea');
            const filtroLinea = elementoFiltro ? elementoFiltro.value : ""; 
            
            const btnCargarMas = document.getElementById('btn-cargar-mas');
            
            if (paginaActual === 1) grid.innerHTML = '';

            let productosFiltrados = [];
            
            if (pestanaActual === 'ofertas') {
                productosFiltrados = inventarioGlobal.filter(p => p.en_promo == 1 && parseFloat(p.descuento_promo) > 0);
            } else if (pestanaActual === 'estancados') {
                productosFiltrados = inventarioEstancados;
            } else {
                productosFiltrados = inventarioGlobal;
            }

            // NUEVO: Aplicar el filtro de línea si hay alguna seleccionada
            if (filtroLinea !== "") {
                productosFiltrados = productosFiltrados.filter(p => p.linea_nombre === filtroLinea);
            }

            // Filtro de búsqueda por texto (Se mantiene igual)
            if (busqueda) {
                const terminos = busqueda.split(' ');
                productosFiltrados = productosFiltrados.filter(p => {
                    const nombreNormalizado = p.nombre.toLowerCase();
                    return terminos.every(termino => nombreNormalizado.includes(termino));
                });
            }

            // 🛡️ ESCUDO ANTI-ERRORES: Si por algún motivo no es un Array...
            if (!Array.isArray(productosFiltrados)) {
                console.warn("⚠️ Advertencia: productosFiltrados no es un Array. Forzando corrección.");
                productosFiltrados = [];
            }

            if (productosFiltrados.length === 0) {
                grid.innerHTML = '<p style="grid-column: 1/-1; text-align: center; color: #666;">No se encontraron productos.</p>';
                btnCargarMas.style.display = 'none';
                return;
            }

            const inicio = (paginaActual - 1) * PRODUCTOS_POR_PAGINA;
            const fin = paginaActual * PRODUCTOS_POR_PAGINA;
            const productosAMostrar = productosFiltrados.slice(inicio, fin);
            
            productosAMostrar.forEach(p => {
                const isSelected = idsSeleccionados.includes(p.id_producto.trim());
                const card = document.createElement('div');
                card.className = `card ${isSelected ? 'selected' : ''}`;
                card.onclick = () => toggleSeleccion(p.id_producto.trim(), card);

                let badge = '';
                if (p.en_promo == 1 && parseFloat(p.descuento_promo) > 0) {
                    let desc = parseFloat(p.descuento_promo);
                    let porcentajeMostrar = desc <= 100 ? desc : Math.round((desc / p.precio_venta_final) * 100);
                    badge = `<div class="badge-promo">-${porcentajeMostrar}%</div>`;
                }

                card.innerHTML = `
                    ${badge}
                    <img src="https://api.surtitodoideal.com${p.proimagenurl}" onerror="this.src='https://api.surtitodoideal.com/static/images/no-image.png'">
                    <h3>${p.nombre.charAt(0).toUpperCase() + p.nombre.slice(1).toLowerCase()}</h3>
                    <div style="color: var(--primary); font-weight: 800; font-size: 1.1rem;">$${Number(p.precio_venta_final).toLocaleString('es-CO')}</div>
                `;
                grid.appendChild(card);
            });

            btnCargarMas.style.display = (fin < productosFiltrados.length) ? 'block' : 'none';
        }

        function toggleSeleccion(id, cardElement) {
            const index = idsSeleccionados.indexOf(id);
            if (index === -1) {
                if (idsSeleccionados.length >= limiteProductos) {
                    alert(`El formato seleccionado solo admite máximo ${limiteProductos} productos.`);
                    return;
                }
                idsSeleccionados.push(id);
                cardElement.classList.add('selected');
            } else {
                idsSeleccionados.splice(index, 1);
                cardElement.classList.remove('selected');
            }
            actualizarBotonFlotante();
            if (document.getElementById('chk-voz-reel')?.checked) {
                generarGuionDesdeProductos();
            } else {
                actualizarContadorGuion();
            }
        }

        function actualizarBotonFlotante() {
            const container = document.getElementById('action-container');
            const btnVolante = document.getElementById('btn-generar');
            
            if (idsSeleccionados.length > 0) {
                container.classList.add('visible'); 
                btnVolante.innerText = `Generar Diseño (${idsSeleccionados.length})`;
            } else {
                container.classList.remove('visible'); 
            }
        }

        async function generarVolante() {
            const btn = document.getElementById('btn-generar');
            const textoOriginal = btn.innerText;
            btn.innerText = '⏳ Diseñando...';
            btn.disabled = true;

            const plantilla = document.getElementById('selector-plantilla').value;
            const tema = document.getElementById('selector-tema').value;
            const orientacion = document.getElementById('selector-orientacion').value;
            
            let tituloPrincipal = document.getElementById('selector-titulo').value;
            if (tituloPrincipal === 'PERSONALIZADO') {
                tituloPrincipal = document.getElementById('input-titulo-manual').value || 'Ofertas Surtitodo';
            }
            const textoTagline = document.getElementById('selector-tagline').value;
            const qrDestino = document.getElementById('selector-qr').value;
            const qrUrlPersonalizada = document.getElementById('input-qr-url').value;
            
            try {
                const res = await fetch('/generar-volante', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        idsSeleccionados,
                        plantilla,
                        tema,
                        tituloPrincipal,
                        textoTagline,
                        orientacion,
                        qrDestino,
                        qrUrlPersonalizada,
                    })
                });
                if (!res.ok) throw new Error('Error en el servidor');

                const blob = await res.blob();
                blobImagenActual = blob;
                const imageUrl = URL.createObjectURL(blob);
                
                document.getElementById('imagen-resultado').src = imageUrl;
                
                const temaSeleccionado = document.getElementById('selector-tema').options[document.getElementById('selector-tema').selectedIndex].text;
                const nombreLimpio = temaSeleccionado.replace(/[^a-zA-Z0-9]/g, '_').replace(/_+/g, '_');
                const fecha = new Date().toISOString().slice(0,10);
                
                document.getElementById('btn-descargar').download = `Volante_${nombreLimpio}_${fecha}.png`;
                document.getElementById('btn-descargar').href = imageUrl;
                
                generarTextoCopy(tituloPrincipal, tema);
                document.getElementById('modal-resultado').style.display = 'flex';
                
            } catch (error) {
                alert('Hubo un error al generar el volante.');
            } finally {
                btn.innerText = textoOriginal;
                btn.disabled = false;
            }
        }

        async function generarTextoCopy(titulo, temaValor) {
            const temaSeleccionado = temaValor || document.getElementById('selector-tema').value;
            const textoTagline = document.getElementById('selector-tagline').value;
            const usarIA = document.getElementById('chk-usar-ia').checked;
            const textarea = document.getElementById('texto-copy');

            textarea.value = '⏳ Generando copy...';

            try {
                const res = await fetch('/api/ia/copy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        idsSeleccionados,
                        titulo,
                        tema: temaSeleccionado,
                        tagline: textoTagline,
                        usarIA,
                    }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error generando copy');

                let copy = data.copyFeed || '';
                if (data.hashtags) copy += `\n\n${data.hashtags}`;
                if (data.fallback && data.aviso) {
                    copy = `ℹ️ ${data.aviso}\n\n${copy}`;
                }
                textarea.value = copy;
            } catch (error) {
                generarTextoCopyLocal(titulo, temaSeleccionado);
            }
        }

        function generarTextoCopyLocal(titulo) {
            const temaSeleccionado = document.getElementById('selector-tema').value;
            const productosElegidos = inventarioGlobal.filter(p => idsSeleccionados.includes(p.id_producto.trim()));
            let copy = '';
        
            // Si es un lanzamiento, el texto arranca diferente
            if (temaSeleccionado === 'lanzamiento') {
                copy = `✨ ¡ATENCIÓN CAICEDONIA! Han llegado cosas increíbles a Surtitodo Ideal ✨\n\n🚨 ¡${titulo}! 🚨\n\nDescubre estas novedades:\n\n`;
            } else {
                copy = `🚨 ¡${titulo} en Surtitodo Ideal! 🚨\n\n`;
            }
            
            productosElegidos.forEach(p => {
                let nombreLimpio = p.nombre.charAt(0).toUpperCase() + p.nombre.slice(1).toLowerCase();
                let precioFinal = Number(p.precio_venta_final);
                
                if (p.en_promo == 1 && parseFloat(p.descuento_promo) > 0) {
                    let desc = parseFloat(p.descuento_promo);
                    if (desc <= 100) {
                        precioFinal = precioFinal * (1 - (desc / 100));
                    } else {
                        precioFinal = Math.max(0, precioFinal - desc);
                    }
                }
                
                // --- NUEVA LÓGICA: CONVERSIÓN DE KILOS A LIBRAS ---
                const regexKilos = /(?:x\s*)?[0-9.,]*\s*(kg|kl)\b/i;
                if (regexKilos.test(nombreLimpio)) {
                    precioFinal = precioFinal / 2;
                    nombreLimpio = nombreLimpio.replace(regexKilos, '').trim() + ' x Libra';
                }
                // --------------------------------------------------
                
                precioFinal = Math.round(precioFinal);
                let precioFormato = precioFinal.toLocaleString('es-CO');
                
                // Mensaje del producto
                if (temaSeleccionado === 'lanzamiento') {
                    copy += `🆕 ${nombreLimpio} ➡️ Precio de Estreno: $${precioFormato}\n`;
                } else {
                    copy += `✅ ${nombreLimpio} ➡️ por solo $${precioFormato}\n`;
                }
            });
        
            copy += `\n🛒 Pide sin salir de casa en:\n🌐 surtitodoideal.com\n\n`;
            copy += `📱 WhatsApp: 312 840 6312\n\n`;
            
            if (temaSeleccionado === 'lanzamiento') {
                copy += `#SurtitodoIdeal #Caicedonia #NuevosIngresos #Novedades`;
            } else {
                copy += `#SurtitodoIdeal #Caicedonia #Ofertas #MercadoEnCasa`;
            }
            
            document.getElementById('texto-copy').value = copy;
        }

        function copiarCopy() {
            const texto = document.getElementById("texto-copy");
            texto.select();
            document.execCommand("copy");
            alert("✅ ¡Texto copiado!");
        }

        function cerrarModal() {
            document.getElementById('modal-resultado').style.display = 'none';
        }

        function cambiarLimitePlantilla() {
            limiteProductos = parseInt(document.getElementById('selector-plantilla').value);
            if (idsSeleccionados.length > limiteProductos) {
                idsSeleccionados = idsSeleccionados.slice(0, limiteProductos);
                renderizarGrilla();
                actualizarBotonFlotante();
            }
        }

        function obtenerTituloCampana() {
            let titulo = document.getElementById('selector-titulo').value;
            if (titulo === 'PERSONALIZADO') {
                titulo = document.getElementById('input-titulo-manual').value.trim() || 'Ofertas Surtitodo';
            }
            return titulo;
        }

        function onGuionEditadoPorUsuario() {
            guionEditadoPorUsuario = true;
            actualizarContadorGuion();
        }

        function onTituloCampanaCambio() {
            if (document.getElementById('chk-voz-reel')?.checked && !guionEditadoPorUsuario) {
                generarGuionDesdeProductos();
            }
        }

        async function generarGuionDesdeProductos(forzar = false) {
            const textarea = document.getElementById('guion-voz-manual');
            if (!textarea) return;

            if (!document.getElementById('chk-voz-reel')?.checked) return;

            if (idsSeleccionados.length === 0) {
                textarea.value = '';
                textarea.placeholder = 'Selecciona productos para generar el guion automáticamente...';
                actualizarContadorGuion();
                return;
            }

            if (guionEditadoPorUsuario && !forzar) return;

            textarea.placeholder = 'Generando guion desde productos seleccionados...';
            textarea.disabled = true;

            try {
                const res = await fetch('/api/tier4/guion-voz', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        idsSeleccionados,
                        titulo: obtenerTituloCampana(),
                        plantillaVideo: document.getElementById('selector-plantilla-video')?.value || 'PromoReel',
                    }),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'No se pudo generar el guion');

                textarea.value = data.guion;
                textarea.placeholder = 'Puedes editar este texto antes de crear el reel.';
                if (forzar) guionEditadoPorUsuario = false;
                await actualizarContadorGuion();
            } catch (error) {
                textarea.placeholder = 'Error al generar guion. Escribe tu texto manualmente.';
            } finally {
                textarea.disabled = false;
            }
        }

        function regenerarGuionDesdeProductos() {
            if (idsSeleccionados.length === 0) {
                alert('Selecciona al menos un producto para generar el guion.');
                return;
            }
            guionEditadoPorUsuario = false;
            generarGuionDesdeProductos(true);
        }

        function verificarTituloManual() {
            const selector = document.getElementById('selector-titulo');
            const inputManual = document.getElementById('input-titulo-manual');
            if (selector.value === 'PERSONALIZADO') {
                inputManual.style.display = 'block';
                inputManual.focus();
            } else {
                inputManual.style.display = 'none';
            }
        }

        async function generarVideoRemotion() {
            if (idsSeleccionados.length === 0) {
                alert("¡Selecciona al menos un producto para el video!");
                return;
            }

            const plantillaVideo = document.getElementById('selector-plantilla-video').value;
            const usarVoz = document.getElementById('chk-voz-reel').checked;
            const guionVozManual = document.getElementById('guion-voz-manual').value;
            const vozId = document.getElementById('selector-voz').value;
            let tituloReel = document.getElementById('selector-titulo').value;
            if (tituloReel === 'PERSONALIZADO') {
                tituloReel = document.getElementById('input-titulo-manual').value || '';
            }
            const btn = document.getElementById('btn-generar-video');
            btn.disabled = true;
            mostrarCarga(usarVoz ? '🎬 Renderizando reel con voz...' : '🎬 Renderizando reel a 60fps...');
            
            try {
                const res = await fetch('/generar-video', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        idsSeleccionados,
                        plantillaVideo,
                        usarVoz,
                        guionVozManual,
                        tituloReel: tituloReel || undefined,
                        vozId,
                    })
                });
                if (res.ok) {
                    const data = await res.json();
                    const fecha = new Date().toISOString().slice(0, 10);
                    const nombre = data.nombreArchivo || `Reel_${plantillaVideo}_${fecha}.mp4`;
                    await mostrarVideo(data.urlVideo, nombre);
                } else {
                    const err = await res.json().catch(() => ({}));
                    alert(err.error || "Hubo un error al generar el video. Revisa la consola del servidor.");
                }
            } catch (error) {
                console.error(error);
                alert(error.message || "Error de conexión con el servidor.");
            } finally {
                ocultarCarga();
                btn.disabled = false;
            }
        }

        function toggleQrPersonalizado() {
            const selector = document.getElementById('selector-qr');
            const input = document.getElementById('input-qr-url');
            input.style.display = selector.value === 'personalizado' ? 'block' : 'none';
        }

        function toggleGuionVoz() {
            const chk = document.getElementById('chk-voz-reel');
            const contenedor = document.getElementById('contenedor-voz-opciones');
            contenedor.style.display = chk.checked ? 'block' : 'none';
            if (chk.checked) {
                generarGuionDesdeProductos(true);
            } else {
                guionEditadoPorUsuario = false;
            }
        }

        async function actualizarContadorGuion() {
            const contador = document.getElementById('guion-contador');
            if (!contador) return;

            const plantilla = document.getElementById('selector-plantilla-video')?.value || 'PromoReel';
            const numProductos = Math.max(1, idsSeleccionados.length);
            const guion = document.getElementById('guion-voz-manual')?.value || '';

            try {
                const params = new URLSearchParams({
                    plantilla,
                    productos: String(numProductos),
                    guion,
                });
                const res = await fetch(`/api/tier4/estimacion-guion?${params}`);
                const data = await res.json();

                const color = data.excedeVideo ? '#b45309' : '#059669';
                const icono = data.excedeVideo ? '⚠️' : '✅';

                contador.innerHTML = `
                    <strong style="color:${color}">${icono} ${data.palabrasActuales} palabras · ~${data.segundosEstimados}s de voz</strong><br>
                    Video <em>${plantilla}</em> (${numProductos} producto${numProductos > 1 ? 's' : ''}): ~<strong>${data.duracionVideoSeg}s</strong> · Máx recomendado: <strong>${data.palabrasRecomendadas} palabras</strong><br>
                    <span style="color:${data.excedeVideo ? '#b45309' : '#666'}">${data.nota}</span>
                `;
            } catch (e) {
                contador.textContent = 'No se pudo calcular la estimación del guion.';
            }
        }

        async function cargarEstadoTier4() {
            const el = document.getElementById('tier4-status');
            if (!el) return;
            try {
                const res = await fetch('/api/tier4/status');
                const data = await res.json();
                const ia = data.iaConfigurada ? '✅ Gemini listo' : '⚠️ Sin GEMINI_API_KEY (copy local)';
                el.textContent = `${ia} · Voz: ${data.proveedorVoz} · QR gratis. Nada de OpenAI ni tarjeta.`;
                if (!data.iaConfigurada) {
                    document.getElementById('chk-usar-ia').checked = false;
                }
                if (data.vozPorDefecto && document.getElementById('selector-voz')) {
                    document.getElementById('selector-voz').value = data.vozPorDefecto;
                }
            } catch (e) {
                el.textContent = 'Modo gratuito: QR y voz sin costo. Copy local si no hay API key.';
            }
        }

        cargarEstadoTier4();
        actualizarResumenLimpieza();

        async function actualizarResumenLimpieza() {
            const el = document.getElementById('limpieza-resumen');
            const btn = document.getElementById('btn-limpiar-archivos');
            if (!el) return;

            el.textContent = 'Calculando espacio usado...';
            if (btn) btn.disabled = true;

            try {
                const res = await fetch('/api/limpieza/resumen');
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error al leer archivos');

                if (data.totalArchivos === 0) {
                    el.innerHTML = '✅ No hay archivos generados acumulados. La Mac está limpia.';
                } else {
                    const lineas = data.categorias
                        .filter((c) => c.cantidad > 0)
                        .map((c) => `• <strong>${c.nombre}</strong>: ${c.cantidad} archivo${c.cantidad > 1 ? 's' : ''} (${c.tamano})`)
                        .join('<br>');
                    el.innerHTML = `
                        <strong>Total: ${data.totalTamano}</strong> en ${data.totalArchivos} archivo${data.totalArchivos > 1 ? 's' : ''}<br><br>
                        ${lineas}
                        ${data.renderEnCurso ? '<br><br>⚠️ Hay un render en curso. Espera a que termine para limpiar.' : ''}
                    `;
                }

                if (btn) {
                    btn.disabled = data.renderEnCurso || data.totalArchivos === 0;
                    btn.style.opacity = btn.disabled ? '0.5' : '1';
                }
            } catch (error) {
                el.textContent = 'No se pudo calcular el espacio usado.';
            }
        }

        async function ejecutarLimpieza() {
            const resPreview = await fetch('/api/limpieza/resumen');
            const preview = await resPreview.json();
            if (!resPreview.ok) {
                alert(preview.error || 'No se pudo verificar los archivos.');
                return;
            }
            if (preview.totalArchivos === 0) {
                alert('No hay archivos generados para eliminar.');
                return;
            }
            if (preview.renderEnCurso) {
                alert('Hay un reel renderizándose. Espera a que termine.');
                return;
            }

            const detalle = preview.categorias
                .filter((c) => c.cantidad > 0)
                .map((c) => `${c.nombre}: ${c.cantidad} (${c.tamano})`)
                .join('\n');

            const confirmar = confirm(
                `¿Eliminar ${preview.totalArchivos} archivo(s) y liberar ${preview.totalTamano}?\n\n${detalle}\n\nLos volantes no se guardan en la Mac (solo en tu iPad). Esta acción no se puede deshacer.`
            );
            if (!confirmar) return;

            const btn = document.getElementById('btn-limpiar-archivos');
            if (btn) {
                btn.disabled = true;
                btn.textContent = '⏳ Eliminando...';
            }

            try {
                const res = await fetch('/api/limpieza/ejecutar', { method: 'POST' });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error al limpiar');

                alert(`✅ Listo. Se eliminaron ${data.eliminados} archivo(s) y se liberaron ${data.bytesLiberadosFmt}.`);
                urlVideoActual = null;
                blobVideoActual = null;
                await actualizarResumenLimpieza();
            } catch (error) {
                alert(error.message || 'Error al eliminar archivos.');
            } finally {
                if (btn) {
                    btn.textContent = '🗑️ Liberar espacio';
                    btn.disabled = false;
                }
            }
        }

        function toggleTheme() {
            document.body.classList.toggle('dark-theme');
            const isDark = document.body.classList.contains('dark-theme');
            localStorage.setItem('surtitodo-theme', isDark ? 'dark' : 'light');
            document.getElementById('theme-toggle').innerText = isDark ? '☀️' : '🌙';
        }

        if (localStorage.getItem('surtitodo-theme') === 'dark') {
            document.body.classList.add('dark-theme');
            document.getElementById('theme-toggle').innerText = '☀️';
        }

        // 🔄 FUNCIÓN PARA CAMBIAR ENTRE VIDEOS ESPECIALES 🔄
        function cambiarVideoEspecial() {
            const selector = document.getElementById('selector-video-especial').value;
            const divTutorial = document.getElementById('contenedor-tutorial');
            const divCliente = document.getElementById('contenedor-cliente-oferta');

            if (selector === 'tutorial') {
                divTutorial.style.display = 'block';
                divCliente.style.display = 'none';
            } else if (selector === 'cliente_oferta') {
                divTutorial.style.display = 'none';
                divCliente.style.display = 'block';
            }
        }

        // 🎬 NUEVA FUNCIÓN PARA EL TUTORIAL 🎬
        async function generarTutorial() {
            const btn = document.getElementById('btn-tutorial');
            const textoOriginal = btn.innerText;
            btn.innerText = '⏳ Renderizando...';
            btn.disabled = true;
            mostrarCarga('📱 Generando reel tutorial...');

            try {
                const res = await fetch('/render-tutorial', { method: 'POST' });
                const data = await res.json();
                
                if(data.success) {
                    await mostrarVideo(data.url, 'tutorial_surtitodo.mp4');
                } else {
                    alert(data.error || "Hubo un error al generar el tutorial. Revisa la consola de tu servidor.");
                }
            } catch(error) {
                console.error(error);
                alert(error.message || "Error de conexión con el servidor.");
            } finally {
                ocultarCarga();
                btn.innerText = textoOriginal;
                btn.disabled = false;
            }
        }

        // 🎬 FUNCIÓN PARA GENERAR EL REEL DEL CLIENTE 🎬
        async function generarReelCliente() {
            const btn = document.getElementById('btn-reel-cliente');
            const form = document.getElementById('form-reel-cliente');
            
            // Validar que el formulario esté lleno
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const textoOriginal = btn.innerText;
            btn.innerText = '⏳ Subiendo y renderizando...';
            btn.disabled = true;
            btn.style.background = '#666';
            mostrarCarga('🎉 Generando reel del cliente...');

            const formData = new FormData(form);

            try {
                const res = await fetch('/generar-reel-cliente', { 
                    method: 'POST',
                    body: formData 
                });
                
                const data = await res.json();
                
                if(data.success) {
                    const fecha = new Date().toISOString().slice(0, 10);
                    await mostrarVideo(data.url, `Reel_Cliente_${fecha}.mp4`);
                } else {
                    alert("Hubo un error al generar el Reel: " + (data.error || 'Error desconocido'));
                }
            } catch(error) {
                console.error(error);
                alert(error.message || "Error de conexión con el servidor.");
            } finally {
                ocultarCarga();
                btn.innerText = textoOriginal;
                btn.disabled = false;
                btn.style.background = '#E60000';
            }
        }

        cargarInfoServidor();
        cargarDatos();
    </script>
</body>
