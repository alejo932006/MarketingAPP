        let variantesAB = { a: null, b: null, nombres: {} };

        async function generarVariantesAB() {
            if (idsSeleccionados.length === 0) {
                alert('Selecciona productos primero.');
                return;
            }
            if (!(await validarAntesDeGenerar('volante'))) return;

            const tituloA = prompt('Título Variante A:', document.getElementById('selector-titulo').value === 'PERSONALIZADO'
                ? document.getElementById('input-titulo-manual').value
                : document.getElementById('selector-titulo').value);
            if (!tituloA) return;

            const tituloB = prompt('Título Variante B:', 'Precios de Locura');
            if (!tituloB) return;

            mostrarCarga('🔀 Generando variantes A/B...');

            const plantilla = document.getElementById('selector-plantilla').value;
            const tema = document.getElementById('selector-tema').value;
            const orientacion = document.getElementById('selector-orientacion').value;
            const textoTagline = document.getElementById('selector-tagline').value;

            try {
                const base = { idsSeleccionados, plantilla, tema, orientacion, textoTagline };
                const [resA, resB] = await Promise.all([
                    fetch('/generar-volante', { method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ ...base, tituloPrincipal: tituloA }) }),
                    fetch('/generar-volante', { method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ ...base, tituloPrincipal: tituloB }) }),
                ]);
                if (!resA.ok || !resB.ok) throw new Error('Error generando una de las variantes');

                const blobA = await resA.blob();
                const blobB = await resB.blob();
                const urlA = URL.createObjectURL(blobA);
                const urlB = URL.createObjectURL(blobB);

                variantesAB = {
                    a: blobA, b: blobB,
                    nombres: {
                        a: `Volante_A_${tituloA.replace(/\s+/g, '_')}.png`,
                        b: `Volante_B_${tituloB.replace(/\s+/g, '_')}.png`,
                    },
                };

                document.getElementById('ab-label-a').innerText = 'A: ' + tituloA;
                document.getElementById('ab-label-b').innerText = 'B: ' + tituloB;
                document.getElementById('ab-img-a').src = urlA;
                document.getElementById('ab-img-b').src = urlB;
                document.getElementById('modal-ab').style.display = 'flex';
            } catch (e) {
                alert(e.message || 'Error generando variantes A/B');
            } finally {
                ocultarCarga();
            }
        }

        async function guardarVarianteAB(letra) {
            const blob = variantesAB[letra];
            if (!blob) return;
            await guardarArchivo(blob, variantesAB.nombres[letra], 'image/png');
        }

