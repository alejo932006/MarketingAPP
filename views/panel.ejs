    <div id="loading-overlay" class="loading-overlay">
        <div class="loading-box">
            <div class="loading-spinner"></div>
            <p id="loading-text" style="margin: 0; font-weight: 600; color: #333;">Renderizando video...</p>
            <div class="progress-bar-wrap">
                <div id="loading-progress" class="progress-bar-fill"></div>
            </div>
            <p id="loading-porcentaje">0%</p>
            <p id="loading-hint" style="margin: 10px 0 0; font-size: 12px; color: #888;">La Mac hace el trabajo pesado. La 1ª vez puede tardar 2-3 min.</p>
        </div>
    </div>

    <script>
        const esDispositivoIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
        let urlImagenActual = null;
        let urlVideoActual = null;
        let blobImagenActual = null;
        let blobVideoActual = null;
        let inventarioGlobal = [];
        let idsSeleccionados = [];
        let pestanaActual = 'ofertas';
        let paginaActual = 1;
        const PRODUCTOS_POR_PAGINA = 50;
        let limiteProductos = 4;
        let inventarioEstancados = [];
        let intervaloProgreso = null;
        let intervaloCampana = null;
        let intervaloLote = null;
        let loteResultadosCache = [];
        const WHATSAPP_NUM = '573128406312';
        let campanaAssets = {
            feed: null, feedBlob: null,
            historia: null, historiaBlob: null,
            reel: null, reelBlob: null,
            nombres: {},
        };

        async function guardarArchivo(blob, nombre, mimeType) {
            if (!blob) {
                alert('El archivo aún no está listo. Espera un momento e intenta de nuevo.');
                return;
            }

            const file = new File([blob], nombre, { type: mimeType || blob.type || 'application/octet-stream' });

            if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
                try {
                    await navigator.share({ files: [file], title: 'Surtitodo Ideal' });
                    return;
                } catch (e) {
                    if (e.name === 'AbortError') return;
                }
            }

            const blobUrl = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = blobUrl;
            link.download = nombre;
            link.style.display = 'none';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            setTimeout(() => URL.revokeObjectURL(blobUrl), 2000);
        }

        async function obtenerBlob(url, cacheKey, cacheObj) {
            if (cacheObj[cacheKey]) return cacheObj[cacheKey];
            const res = await fetch(url);
            if (!res.ok) throw new Error('No se pudo cargar el archivo');
            const blob = await res.blob();
            cacheObj[cacheKey] = blob;
            return blob;
        }

        function configurarBotonesIOS() {
            if (!esDispositivoIOS) return;

            document.getElementById('campana-footer-label-archivos').innerText = 'Guardar en iPad';
            document.getElementById('btn-dl-feed').innerText = '📤 Feed';
            document.getElementById('btn-dl-historia').innerText = '📤 Historia';
            document.getElementById('btn-dl-reel').innerText = '📤 Reel';
            document.getElementById('hint-campana-ios').classList.add('visible');

            const btnDlImg = document.getElementById('btn-descargar');
            if (btnDlImg) {
                btnDlImg.innerText = '📤 Guardar imagen';
                btnDlImg.onclick = (e) => { e.preventDefault(); compartirImagen(); return false; };
            }

            const btnDlVid = document.getElementById('btn-descargar-video');
            if (btnDlVid) {
                btnDlVid.innerText = '📤 Guardar video';
                btnDlVid.onclick = (e) => { e.preventDefault(); compartirVideo(); return false; };
            }
        }

        function descargarVolanteActual(event) {
            if (esDispositivoIOS) {
                event.preventDefault();
                compartirImagen();
                return false;
            }
            return true;
        }

        function descargarVideoActual(event) {
            if (esDispositivoIOS) {
                event.preventDefault();
                compartirVideo();
                return false;
            }
            return true;
        }

        async function guardarCampanaArchivo(tipo) {
            const map = {
                feed: { url: campanaAssets.feed, key: 'feedBlob', mime: 'image/png' },
                historia: { url: campanaAssets.historia, key: 'historiaBlob', mime: 'image/png' },
                reel: { url: campanaAssets.reel, key: 'reelBlob', mime: 'video/mp4' },
            };
            const item = map[tipo];
            if (!item || !item.url) return;

            const btn = document.getElementById('btn-dl-' + tipo);
            const textoOriginal = btn ? btn.innerText : '';
            if (btn) { btn.disabled = true; btn.innerText = '⏳...'; }

            try {
                const blob = await obtenerBlob(item.url, item.key, campanaAssets);
                const nombre = campanaAssets.nombres[tipo] || `archivo_${tipo}`;
                await guardarArchivo(blob, nombre, item.mime);
            } catch (e) {
                alert('No se pudo guardar el archivo. Intenta de nuevo.');
            } finally {
                if (btn) {
                    btn.disabled = false;
                    btn.innerText = textoOriginal;
                }
            }
        }

        async function guardarArchivoHistorial(url, nombre, mimeType) {
            try {
                const res = await fetch(url);
                if (!res.ok) throw new Error();
                const blob = await res.blob();
                await guardarArchivo(blob, nombre, mimeType);
            } catch (e) {
                alert('No se pudo abrir el archivo del historial.');
            }
        }

        function obtenerConfigActual() {
            let tituloPrincipal = document.getElementById('selector-titulo').value;
            if (tituloPrincipal === 'PERSONALIZADO') {
                tituloPrincipal = document.getElementById('input-titulo-manual').value || 'Ofertas Surtitodo';
            }
            return {
                plantilla: document.getElementById('selector-plantilla').value,
                tema: document.getElementById('selector-tema').value,
                orientacion: document.getElementById('selector-orientacion').value,
                tituloPrincipal,
                textoTagline: document.getElementById('selector-tagline').value,
                plantillaVideo: document.getElementById('selector-plantilla-video').value,
                idsSeleccionados: [...idsSeleccionados],
            };
        }

        function aplicarConfig(config) {
            if (!config) return;
            if (config.plantilla) {
                document.getElementById('selector-plantilla').value = config.plantilla;
                cambiarLimitePlantilla();
            }
            if (config.tema) document.getElementById('selector-tema').value = config.tema;
            if (config.orientacion) document.getElementById('selector-orientacion').value = config.orientacion;
            if (config.tituloPrincipal) {
                const sel = document.getElementById('selector-titulo');
                const opciones = [...sel.options].map(o => o.value);
                if (opciones.includes(config.tituloPrincipal)) {
                    sel.value = config.tituloPrincipal;
                    document.getElementById('input-titulo-manual').style.display = 'none';
                } else {
                    sel.value = 'PERSONALIZADO';
                    document.getElementById('input-titulo-manual').value = config.tituloPrincipal;
                    document.getElementById('input-titulo-manual').style.display = 'block';
                }
            }
            if (config.textoTagline) document.getElementById('selector-tagline').value = config.textoTagline;
            if (config.plantillaVideo) document.getElementById('selector-plantilla-video').value = config.plantillaVideo;
            if (config.idsSeleccionados && config.idsSeleccionados.length) {
                idsSeleccionados = config.idsSeleccionados.map(String);
                renderizarGrilla();
                actualizarBotonFlotante();
            }
            actualizarValidacion();
        }

        async function actualizarValidacion() {
            const panel = document.getElementById('validacion-panel');
            if (idsSeleccionados.length === 0) {
                panel.classList.remove('visible', 'error', 'warning', 'ok');
                return;
            }

            try {
                const config = obtenerConfigActual();
                const res = await fetch('/api/validar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        idsSeleccionados,
                        plantilla: config.plantilla,
                        plantillaVideo: config.plantillaVideo,
                        modo: 'ambos',
                    }),
                });
                const v = await res.json();
                panel.classList.add('visible');
                panel.classList.remove('error', 'warning', 'ok');

                let html = '';
                if (!v.valido) {
                    panel.classList.add('error');
                    html = '<strong>❌ Corrige antes de generar:</strong><ul>' +
                        v.errores.map(e => `<li>${e}</li>`).join('') + '</ul>';
                } else if (v.advertencias && v.advertencias.length) {
                    panel.classList.add('warning');
                    html = '<strong>⚠️ Advertencias:</strong><ul>' +
                        v.advertencias.map(a => `<li>${a}</li>`).join('') + '</ul>';
                } else {
                    panel.classList.add('ok');
                    html = '✅ Selección válida — listo para generar.';
                }
                panel.innerHTML = html;
            } catch (e) {
                panel.classList.remove('visible');
            }
        }

        async function validarAntesDeGenerar(modo) {
            const config = obtenerConfigActual();
            const res = await fetch('/api/validar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    idsSeleccionados,
                    plantilla: config.plantilla,
                    plantillaVideo: config.plantillaVideo,
                    modo,
                }),
            });
            const v = await res.json();
            if (!v.valido) {
                alert('❌ ' + v.errores.join('\n'));
                return false;
            }
            if (v.advertencias && v.advertencias.length) {
                const continuar = confirm('⚠️ Advertencias:\n\n' + v.advertencias.join('\n') + '\n\n¿Continuar de todos modos?');
                if (!continuar) return false;
            }
            return true;
        }

        function calcularPorcentajeDescuento(p) {
            const desc = parseFloat(p.descuento_promo || 0);
            if (desc <= 0) return 0;
            return desc <= 100 ? desc : Math.round((desc / p.precio_venta_final) * 100);
        }

        async function aplicarSugerencia(tipo) {
            const limite = limiteProductos;

            if (tipo === 'estancados') {
                if (inventarioEstancados.length === 0) {
                    try {
                        const res = await fetch('/api/local-estancados');
                        inventarioEstancados = await res.json();
                    } catch (e) {
                        alert('No se pudieron cargar los estancados.');
                        return;
                    }
                }
                if (!inventarioEstancados.length) {
                    alert('No hay productos estancados en este momento.');
                    return;
                }
                idsSeleccionados = inventarioEstancados.slice(0, limite).map(p => p.id_producto.toString().trim());
            } else if (tipo === 'mejorDescuento') {
                const ofertas = inventarioGlobal
                    .filter(p => p.en_promo == 1 && parseFloat(p.descuento_promo) > 0)
                    .sort((a, b) => calcularPorcentajeDescuento(b) - calcularPorcentajeDescuento(a));
                if (!ofertas.length) {
                    alert('No hay ofertas activas.');
                    return;
                }
                idsSeleccionados = [ofertas[0].id_producto.toString().trim()];
            } else {
                const ofertas = inventarioGlobal
                    .filter(p => p.en_promo == 1 && parseFloat(p.descuento_promo) > 0)
                    .sort((a, b) => calcularPorcentajeDescuento(b) - calcularPorcentajeDescuento(a));
                if (!ofertas.length) {
                    alert('No hay ofertas activas.');
                    return;
                }
                idsSeleccionados = ofertas.slice(0, limite).map(p => p.id_producto.toString().trim());
            }

            renderizarGrilla();
            actualizarBotonFlotante();
            actualizarValidacion();
        }

        async function cargarPresets() {
            try {
                const res = await fetch('/api/presets');
                const presets = await res.json();
                const cont = document.getElementById('presets-lista');
                if (!presets.length) {
                    cont.innerHTML = '<p style="color: #888; font-size: 13px; margin: 0;">No hay presets guardados.</p>';
                    return;
                }
                cont.innerHTML = presets.map(p => `
                    <div class="preset-item">
                        <span>${p.nombre}</span>
                        <div style="display:flex; gap:6px;">
                            <button onclick="aplicarPreset('${p.id}')">Cargar</button>
                            <button class="btn-borrar" onclick="borrarPreset('${p.id}')">✕</button>
                        </div>
                    </div>
                `).join('');
                window._presetsCache = presets;
            } catch (e) {
                console.warn('Error cargando presets');
            }
        }

        async function guardarPreset() {
            const nombre = document.getElementById('input-preset-nombre').value.trim();
            if (!nombre) {
                alert('Escribe un nombre para el preset.');
                return;
            }
            const config = obtenerConfigActual();
            const res = await fetch('/api/presets', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre, config }),
            });
            if (res.ok) {
                document.getElementById('input-preset-nombre').value = '';
                cargarPresets();
                alert('✅ Preset guardado.');
            }
        }

        function aplicarPreset(id) {
            const preset = (window._presetsCache || []).find(p => p.id === id);
            if (preset) aplicarConfig(preset.config);
        }

        async function borrarPreset(id) {
            if (!confirm('¿Eliminar este preset?')) return;
            await fetch('/api/presets/' + id, { method: 'DELETE' });
            cargarPresets();
        }

        async function cargarHistorial() {
            try {
                const res = await fetch('/api/historial');
                const historial = await res.json();
                const cont = document.getElementById('historial-lista');
                if (!historial.length) {
                    cont.innerHTML = '<p style="color: #888; font-size: 13px; margin: 0;">Sin campañas guardadas aún.</p>';
                    return;
                }
                cont.innerHTML = historial.slice(0, 15).map(h => {
                    const fecha = new Date(h.fecha).toLocaleString('es-CO', { dateStyle: 'short', timeStyle: 'short' });
                    const tipo = h.tipo === 'campana' ? '🚀 Campaña' : h.tipo === 'lote' ? '📦 Lote' : h.tipo === 'reel' ? '🎬 Reel' : '🖼️ Volante';
                    const titulo = h.titulo || h.plantillaVideo || 'Generación';
                    const productos = (h.nombresProductos || []).slice(0, 3).join(', ');
                    let acciones = `<button class="btn-repetir" onclick="repetirHistorial('${h.id}')">↻ Repetir</button>`;
                    const fechaArch = new Date(h.fecha).toISOString().slice(0, 10);
                    if (h.volanteFeed) acciones += `<button onclick="guardarArchivoHistorial('${h.volanteFeed}','Feed_${fechaArch}.png','image/png')">Feed</button>`;
                    if (h.volanteHistoria) acciones += `<button onclick="guardarArchivoHistorial('${h.volanteHistoria}','Historia_${fechaArch}.png','image/png')">Historia</button>`;
                    if (h.reel) acciones += `<button onclick="guardarArchivoHistorial('${h.reel}','Reel_${fechaArch}.mp4','video/mp4')">Reel</button>`;
                    if (h.tipo === 'lote' && h.resultados?.length) {
                        acciones += `<button onclick="verLoteHistorial('${h.id}')">📦 Ver lote</button>`;
                    }
                    acciones += `<button onclick="borrarHistorial('${h.id}')">✕</button>`;
                    return `<div class="historial-item">
                        <div>
                            <strong>${tipo}: ${titulo}</strong>
                            <div class="meta">${fecha} · ${(h.nombresProductos || []).length} productos</div>
                            <div class="meta">${productos}${(h.nombresProductos || []).length > 3 ? '...' : ''}</div>
                        </div>
                        <div class="acciones">${acciones}</div>
                    </div>`;
                }).join('');
                window._historialCache = historial;
            } catch (e) {
                console.warn('Error cargando historial');
            }
        }

        function repetirHistorial(id) {
            const item = (window._historialCache || []).find(h => h.id === id);
            if (!item) return;
            if (item.idsSeleccionados) {
                idsSeleccionados = item.idsSeleccionados.map(String);
            }
            aplicarConfig({
                tituloPrincipal: item.titulo,
                tema: item.tema,
                plantilla: item.plantilla,
                textoTagline: item.textoTagline,
                plantillaVideo: item.plantillaVideo,
                idsSeleccionados: item.idsSeleccionados,
            });
            renderizarGrilla();
            actualizarBotonFlotante();
            actualizarValidacion();
            window.scrollTo({ top: document.getElementById('grid-productos').offsetTop - 20, behavior: 'smooth' });
        }

        async function borrarHistorial(id) {
            if (!confirm('¿Eliminar del historial?')) return;
            await fetch('/api/historial/' + id, { method: 'DELETE' });
            cargarHistorial();
        }

        function abrirWhatsApp(texto) {
            window.open(`https://wa.me/${WHATSAPP_NUM}?text=${encodeURIComponent(texto)}`, '_blank');
        }

        function compartirWhatsApp() {
            const copy = document.getElementById('texto-copy').value;
            if (!copy) return;
            abrirWhatsApp(copy);
        }

        function compartirVideoWhatsApp() {
            const copy = document.getElementById('texto-copy').value ||
                '🎬 ¡Nueva oferta en Surtitodo Ideal! Pide en surtitodoideal.com · WhatsApp 312 840 6312';
            abrirWhatsApp(copy + '\n\n(Reel generado — adjunta el video desde tu galería)');
        }

        function copiarCampanaCopy() {
            const texto = document.getElementById('campana-copy');
            texto.select();
            document.execCommand('copy');
            alert('✅ Copy copiado.');
        }

        function compartirCampanaWhatsApp() {
            const copy = document.getElementById('campana-copy').value;
            abrirWhatsApp(copy + '\n\n(Reel y volantes listos — adjunta desde tu galería)');
        }

        async function prepararCampanaAssets(data) {
            const fecha = new Date().toISOString().slice(0, 10);
            campanaAssets = {
                feed: data.volanteFeed,
                feedBlob: null,
                historia: data.volanteHistoria,
                historiaBlob: null,
                reel: data.reel,
                reelBlob: null,
                nombres: {
                    feed: `Volante_Feed_${fecha}.png`,
                    historia: `Volante_Historia_${fecha}.png`,
                    reel: `Reel_Campana_${fecha}.mp4`,
                },
            };

            document.getElementById('campana-feed-img').src = data.volanteFeed + '?t=' + Date.now();
            document.getElementById('campana-historia-img').src = data.volanteHistoria + '?t=' + Date.now();
            document.getElementById('campana-reel-video').src = data.reel + '?t=' + Date.now();
            document.getElementById('campana-copy').value = data.copy;

            Promise.all([
                obtenerBlob(data.volanteFeed, 'feedBlob', campanaAssets).catch(() => null),
                obtenerBlob(data.volanteHistoria, 'historiaBlob', campanaAssets).catch(() => null),
                obtenerBlob(data.reel, 'reelBlob', campanaAssets).catch(() => null),
            ]);

            const body = document.querySelector('.modal-campana-body');
            if (body) body.scrollTop = 0;
        }

        function cerrarModalCampana() {
            document.getElementById('modal-campana').style.display = 'none';
            const video = document.getElementById('campana-reel-video');
            video.pause();
            video.removeAttribute('src');
            campanaAssets = {
                feed: null, feedBlob: null,
                historia: null, historiaBlob: null,
                reel: null, reelBlob: null,
                nombres: {},
            };
        }

        async function generarCampanaCompleta() {
            if (idsSeleccionados.length === 0) {
                alert('Selecciona al menos un producto.');
                return;
            }
            if (!(await validarAntesDeGenerar('campana'))) return;

            const btn = document.getElementById('btn-campana-completa');
            btn.disabled = true;
            mostrarCarga('🚀 Creando campaña completa...');

            if (intervaloCampana) clearInterval(intervaloCampana);
            intervaloCampana = setInterval(async () => {
                try {
                    const [resCampana, resRender] = await Promise.all([
                        fetch('/api/campana-progress'),
                        fetch('/api/render-progress'),
                    ]);
                    const data = await resCampana.json();
                    const render = await resRender.json();

                    let mensaje = data.mensaje || render.mensaje;
                    let porcentaje = data.porcentaje || 0;

                    if (data.fase === 'reel' && render.porcentaje > 0) {
                        porcentaje = 45 + Math.round(render.porcentaje * 0.55);
                        mensaje = render.mensaje || data.mensaje;
                    }

                    if (mensaje) {
                        document.getElementById('loading-text').innerText = mensaje;
                    }
                    if (porcentaje > 0) {
                        document.getElementById('loading-progress').style.width = porcentaje + '%';
                        document.getElementById('loading-porcentaje').innerText = porcentaje + '%';
                    }
                } catch (e) { /* silencioso */ }
            }, 1500);

            const config = obtenerConfigActual();

            try {
                const res = await fetch('/api/campana-completa', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config),
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error generando campaña');

                await prepararCampanaAssets(data);
                document.getElementById('modal-campana').style.display = 'flex';
                cargarHistorial();
            } catch (error) {
                alert(error.message || 'Error generando la campaña.');
            } finally {
                if (intervaloCampana) {
                    clearInterval(intervaloCampana);
                    intervaloCampana = null;
                }
                ocultarCarga();
                btn.disabled = false;
            }
        }

        function mostrarCarga(mensaje) {
            document.getElementById('loading-text').innerText = mensaje || 'Renderizando video...';
            document.getElementById('loading-progress').style.width = '0%';
            document.getElementById('loading-porcentaje').innerText = '0%';
            document.getElementById('loading-overlay').classList.add('visible');

            if (intervaloProgreso) clearInterval(intervaloProgreso);
            intervaloProgreso = setInterval(async () => {
                try {
                    const res = await fetch('/api/render-progress');
                    const data = await res.json();
                    if (data.mensaje) {
                        document.getElementById('loading-text').innerText = data.mensaje;
                    }
                    if (data.porcentaje > 0) {
                        document.getElementById('loading-progress').style.width = data.porcentaje + '%';
                        document.getElementById('loading-porcentaje').innerText = data.porcentaje + '%';
                    }
                } catch (e) { /* silencioso */ }
            }, 1500);
        }

        function ocultarCarga() {
            if (intervaloProgreso) {
                clearInterval(intervaloProgreso);
                intervaloProgreso = null;
            }
            document.getElementById('loading-overlay').classList.remove('visible');
        }

        async function cargarInfoServidor() {
            try {
                const res = await fetch('/api/server-info');
                const info = await res.json();
                const esLocalhost = location.hostname === 'localhost' || location.hostname === '127.0.0.1';
                const banner = document.getElementById('network-banner');
                const ipadUrl = document.getElementById('ipad-url');

                if (esLocalhost && info.localIPs && info.localIPs.length > 0) {
                    const url = `http://${info.localIPs[0]}:${info.port}`;
                    ipadUrl.textContent = url;
                    banner.style.display = 'block';
                } else if (!esLocalhost) {
                    ipadUrl.textContent = info.baseUrl;
                    banner.innerHTML = '<strong>✅ Conectado desde red local</strong> — ' + info.baseUrl;
                    banner.style.display = 'block';
                }

                if (esDispositivoIOS) {
                    document.getElementById('btn-compartir-imagen').style.display = 'inline-block';
                    document.getElementById('hint-imagen-ios').classList.add('visible');
                }
            } catch (e) {
                console.warn('No se pudo cargar info del servidor');
            }
        }

        async function mostrarVideo(url, nombreArchivo) {
            urlVideoActual = url;
            const res = await fetch(url);
            if (!res.ok) {
                throw new Error('No se pudo cargar el video del servidor (archivo no encontrado)');
            }

            const contentType = res.headers.get('content-type') || '';
            blobVideoActual = await res.blob();

            if (blobVideoActual.size < 10000 || contentType.includes('text/html') || contentType.includes('application/json')) {
                throw new Error('El servidor no devolvió un video válido. Revisa la consola de la Mac.');
            }

            const blobUrl = URL.createObjectURL(blobVideoActual);
            const video = document.getElementById('video-resultado');
            video.src = blobUrl;

            document.getElementById('btn-descargar-video').href = blobUrl;
            document.getElementById('btn-descargar-video').download = nombreArchivo || 'reel_surtitodo.mp4';

            document.getElementById('modal-video').style.display = 'flex';
        }

        function cerrarModalVideo() {
            document.getElementById('modal-video').style.display = 'none';
            const video = document.getElementById('video-resultado');
            video.pause();
            if (video.src && video.src.startsWith('blob:')) {
                URL.revokeObjectURL(video.src);
            }
            video.removeAttribute('src');
            video.load();
            blobVideoActual = null;
        }

        async function compartirVideo() {
            if (!blobVideoActual && urlVideoActual) {
                try {
                    const res = await fetch(urlVideoActual);
                    blobVideoActual = await res.blob();
                } catch (e) {
                    alert('No se pudo preparar el video. Intenta abrirlo en una nueva pestaña.');
                    return;
                }
            }
            if (!blobVideoActual) return;

            const nombre = document.getElementById('btn-descargar-video').download || 'reel_surtitodo.mp4';
            const file = new File([blobVideoActual], nombre, { type: 'video/mp4' });

            if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
                try {
                    await navigator.share({ files: [file], title: 'Reel Surtitodo' });
                    return;
                } catch (e) {
                    if (e.name !== 'AbortError') console.warn(e);
                }
            }

            const link = document.createElement('a');
            link.href = URL.createObjectURL(blobVideoActual);
            link.download = nombre;
            link.click();
            alert('💡 Mantén pulsado el video de arriba y elige "Compartir" → "Guardar video" para guardarlo en Fotos.');
        }

        async function compartirImagen() {
            if (!blobImagenActual) return;
            const nombre = document.getElementById('btn-descargar').download || 'volante.png';
            const file = new File([blobImagenActual], nombre, { type: 'image/png' });

            if (navigator.share && navigator.canShare && navigator.canShare({ files: [file] })) {
                try {
                    await navigator.share({ files: [file], title: 'Volante Surtitodo' });
                    return;
                } catch (e) {
                    if (e.name !== 'AbortError') console.warn(e);
                }
            }

            alert('💡 Mantén pulsada la imagen y elige "Guardar en Fotos".');
        }

        function poblarLineas() {
            const selectLinea = document.getElementById('filtro-linea');
            
            // Extraer líneas únicas y eliminar valores nulos o vacíos
            const lineasUnicas = [...new Set(inventarioGlobal.map(p => p.linea_nombre).filter(Boolean))].sort();
            
            // Reiniciar el select
            selectLinea.innerHTML = '<option value="">🛒 Todas las Líneas</option>';
            
            // Llenar con las opciones
            lineasUnicas.forEach(linea => {
                const option = document.createElement('option');
                option.value = linea;
                // Capitalizar para que se vea estético en el panel
                option.textContent = linea.charAt(0).toUpperCase() + linea.slice(1).toLowerCase();
                selectLinea.appendChild(option);
            });
