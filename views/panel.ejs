            } else {
                container.classList.remove('visible');
                dockContador.innerHTML = '<strong>0</strong> productos seleccionados';
            }

            const bannerRemate = document.getElementById('modo-remate-banner');
            if (bannerRemate) {
                bannerRemate.classList.toggle('visible', pestanaActual === 'estancados' && n > 0);
            }
        }

