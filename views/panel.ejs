<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Surtitodo Marketing Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Poppins', sans-serif; background: #f4f6f8; margin: 0; padding: 20px; padding-bottom: 100px; }
        .header { background: #111; color: #FFC300; padding: 20px; border-radius: 10px; text-align: center; margin-bottom: 20px; }
        
        /* Pestañas y Buscador */
        .controls { display: flex; justify-content: space-between; gap: 20px; margin-bottom: 20px; flex-wrap: wrap; }
        .tabs button { background: #ddd; border: none; padding: 10px 20px; font-size: 16px; border-radius: 5px; cursor: pointer; font-family: 'Poppins'; font-weight: bold; transition: 0.2s; }
        .tabs button.active { background: #E60000; color: white; }
        .search-box { flex: 1; min-width: 250px; padding: 10px; border: 2px solid #ccc; border-radius: 5px; font-size: 16px; font-family: 'Poppins'; }
        
        /* Grilla de Selección */
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; }
        .card { background: white; padding: 15px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); text-align: center; cursor: pointer; border: 3px solid transparent; transition: 0.2s; position: relative; }
        .card:hover { transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.15); }
        .card.selected { border-color: #E60000; background: #fff8f8; }
        .card img { width: 100px; height: 100px; object-fit: contain; margin-bottom: 10px; }
        .card h3 { font-size: 14px; margin: 0 0 5px 0; color: #333; }
        .badge-promo { position: absolute; top: -10px; right: -10px; background: #FFC300; color: #111; padding: 5px 10px; border-radius: 20px; font-size: 14px; font-weight: 900; box-shadow: 0 4px 8px rgba(0,0,0,0.2); }
        
        /* Botón Cargar Más */
        .btn-cargar-mas { display: none; margin: 30px auto; background: #333; color: white; border: none; padding: 12px 30px; border-radius: 50px; font-size: 16px; font-weight: bold; cursor: pointer; font-family: 'Poppins'; transition: 0.2s; }
        .btn-cargar-mas:hover { background: #555; transform: scale(1.05); }

        /* Botón Flotante */
        .fab { position: fixed; bottom: 30px; right: 30px; background: #E60000; color: white; border: none; padding: 15px 30px; border-radius: 50px; font-size: 18px; font-weight: bold; box-shadow: 0 10px 20px rgba(230,0,0,0.4); cursor: pointer; display: none; font-family: 'Poppins'; z-index: 100; transition: 0.3s; }
        .fab:hover { background: #cc0000; transform: scale(1.05); }
        
        /* Modal de Previsualización */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); justify-content: center; align-items: center; z-index: 1000; }
        .modal-content { background: white; padding: 20px; border-radius: 10px; text-align: center; max-height: 90vh; display: flex; flex-direction: column; }
        .modal-content img { max-height: 70vh; object-fit: contain; margin-bottom: 15px; border-radius: 10px; border: 2px solid #ccc; }
        .btn-descargar { background: #28a745; color: white; text-decoration: none; padding: 10px 20px; border-radius: 5px; font-weight: bold; margin-right: 10px; }
        .btn-cerrar { background: #666; color: white; padding: 10px 20px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-family: 'Poppins'; }
    </style>
</head>
<body>

    <div class="header">
        <h1 style="margin: 0;">⚙️ Panel de Marketing Surtitodo</h1>
        <p style="margin: 5px 0 0 0; color: #aaa;">Generador automático de volantes</p>
    </div>

    <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 20px; background: white; padding: 15px 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); flex-wrap: wrap;">
        
        <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 250px;">
            <h3 style="margin: 0; font-size: 16px; color: #333;">🖼️ Formato:</h3>
            <select id="selector-plantilla" onchange="cambiarLimitePlantilla()" style="padding: 10px; font-size: 15px; border-radius: 5px; font-family: 'Poppins'; border: 2px solid #ccc; flex: 1; cursor: pointer; background: #f8f9fa;">
                <option value="4">4 Productos</option>
                <option value="2">2 Productos</option>
                <option value="1">1 Producto Gigante</option>
            </select>
        </div>

        <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 250px;">
            <h3 style="margin: 0; font-size: 16px; color: #333;">🎨 Estilo:</h3>
            <select id="selector-tema" style="padding: 10px; font-size: 15px; border-radius: 5px; font-family: 'Poppins'; border: 2px solid #ccc; flex: 1; cursor: pointer; background: #f8f9fa;">
                <option value="clasico">🔴 Clásico Surtitodo</option>
                <option value="vip">⚫ VIP Premium</option>
                <option value="fruver">🟢 Frescura Natural</option>
                <option value="mercado">🍅 Mercado (Foto + Zig-Zag)</option>
                <option value="ecommerce">🛒 Exclusivo Web (Cyber/Digital)</option> 
                <option value="sorpresa">😱 Precios de Locura (Cara Sorprendida)</option>
            </select>
        </div>

    </div>

    <div class="controls">
        <div class="tabs">
            <button id="tab-ofertas" class="active" onclick="cambiarPestana('ofertas')">🔥 Ofertas Activas</button>
            <button id="tab-todos" onclick="cambiarPestana('todos')">🛒 Todo el Catálogo</button>
        </div>
        <input type="text" id="buscador" class="search-box" placeholder="Buscar por nombre..." oninput="reiniciarYRenderizar()">
    </div>

    <div style="margin-bottom: 20px; display: flex; align-items: center; gap: 20px; background: white; padding: 15px 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); flex-wrap: wrap;">
        
        <div style="display: flex; align-items: center; gap: 10px; flex: 2; min-width: 300px;">
            <h3 style="margin: 0; font-size: 16px; color: #333;">🏷️ Título:</h3>
            <select id="selector-titulo" onchange="verificarTituloManual()" style="padding: 10px; font-size: 15px; border-radius: 5px; font-family: 'Poppins'; border: 2px solid #ccc; flex: 1; cursor: pointer; background: #f8f9fa;">
                <option value="Dias De Ahorro">Dias De Ahorro</option>
                <option value="Gran Madrugón">Gran Madrugón</option>
                <option value="Quincena de Ofertas">Quincena de Ofertas</option>
                <option value="Especial de Carnes">Especial de Carnes</option>
                <option value="Cyber Surtitodo">Cyber Surtitodo</option>
                <option value="PERSONALIZADO">✏️ Escribir mi propio título...</option>
            </select>
            <input type="text" id="input-titulo-manual" placeholder="Ej: Feliz Día Mamá" style="display: none; padding: 10px; font-size: 15px; border-radius: 5px; border: 2px solid #E60000; flex: 1; outline: none;">
        </div>

        <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 250px;">
            <h3 style="margin: 0; font-size: 16px; color: #333;">📢 Etiqueta:</h3>
            <select id="selector-tagline" style="padding: 10px; font-size: 15px; border-radius: 5px; font-family: 'Poppins'; border: 2px solid #ccc; flex: 1; cursor: pointer; background: #f8f9fa;">
                <option value="Solo por tiempo limitado">Solo por tiempo limitado</option>
                <option value="¡Aprovecha hoy mismo!">¡Aprovecha hoy mismo!</option>
                <option value="Precios imbatibles">Precios imbatibles</option>
                <option value="Exclusivo Web">Exclusivo Web</option>
            </select>
        </div>

        <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 250px;">
            <h3 style="margin: 0; font-size: 16px; color: #333;">📱 Tamaño:</h3>
            <select id="selector-orientacion" style="padding: 10px; font-size: 15px; border-radius: 5px; font-family: 'Poppins'; border: 2px solid #ccc; flex: 1; cursor: pointer; background: #f8f9fa;">
                <option value="feed">Feed / Cuadrado (1080x1350)</option>
                <option value="historia">Historia / Reel (1080x1920)</option>
            </select>
        </div>

    </div>

    <div id="grid-productos" class="grid">
        <p style="grid-column: 1/-1; text-align: center;">Cargando inventario desde el servidor...</p>
    </div>

    <button id="btn-cargar-mas" class="btn-cargar-mas" onclick="cargarMas()">⬇️ Cargar 50 productos más</button>

    <button id="btn-generar" class="fab" onclick="generarVolante()">Generar Volante (0)</button>

    <button onclick="generarVideoRemotion()" style="background: #E60000; color: white; padding: 15px 30px; font-size: 20px; font-weight: bold; border: none; border-radius: 10px; cursor: pointer; box-shadow: 0 5px 15px rgba(230, 0, 0, 0.4);">
        🎬 Generar Video (Reel)
    </button>
    
    <div id="cargando-video" style="display: none; margin-top: 15px; font-weight: bold; color: #E60000;">
        ⏳ Tu i9 está renderizando el video a 60fps... Por favor espera unos segundos.
    </div>

    <div id="modal-resultado" class="modal">
        <div class="modal-content" style="max-width: 500px; max-height: 90vh; overflow-y: auto;">
            <h2 style="margin-top: 0;">¡Volante Listo! 🎉</h2>
            <img id="imagen-resultado" src="" alt="Volante">
            <div style="margin-bottom: 20px;">
                <a id="btn-descargar" class="btn-descargar" href="#" download="volante.png">⬇️ Descargar PNG</a>
                <button class="btn-cerrar" onclick="cerrarModal()">Cerrar</button>
            </div>
            
            <div style="text-align: left; background: #f8f9fa; padding: 15px; border-radius: 10px; border: 2px dashed #ccc;">
                <h3 style="margin: 0 0 10px 0; font-size: 16px;">📝 Texto sugerido para la publicación:</h3>
                <textarea id="texto-copy" readonly style="width: 100%; height: 250px; padding: 10px; font-family: 'Poppins'; border-radius: 5px; border: 1px solid #ddd; resize: vertical; overflow-y: auto;"></textarea>
                <button onclick="copiarCopy()" style="margin-top: 10px; width: 100%; padding: 10px; background: #111; color: #FFC300; font-weight: bold; border: none; border-radius: 5px; cursor: pointer;">📋 Copiar Texto</button>
            </div>
        </div>
    </div>

    <script>
        let inventarioGlobal = [];
        let idsSeleccionados = [];
        let pestanaActual = 'ofertas';
        
        // Variables para la paginación
        let paginaActual = 1;
        const PRODUCTOS_POR_PAGINA = 50;

        // 1. Cargar datos de la API
        async function cargarDatos() {
            try {
                // Usamos el puente local para evitar el problema de CORS
                const res = await fetch('/api/local-products'); 
                const data = await res.json();
                
                // Filtramos productos válidos (con imagen, precio mayor a 0 y que no estén ocultos)
                inventarioGlobal = data.filter(p => p.proimagenurl && p.precio_venta_final > 0 && !p.oculto);
                renderizarGrilla();
            } catch (error) {
                document.getElementById('grid-productos').innerHTML = '<p style="color:red; grid-column: 1/-1; text-align: center;">Error conectando a la API.</p>';
            }
        }

        // 2. Cambiar de pestaña
        function cambiarPestana(pestana) {
            pestanaActual = pestana;
            document.getElementById('tab-ofertas').classList.toggle('active', pestana === 'ofertas');
            document.getElementById('tab-todos').classList.toggle('active', pestana === 'todos');
            reiniciarYRenderizar();
        }

        // 3. Reiniciar la página a 1 cada vez que se busca o se cambia de pestaña
        function reiniciarYRenderizar() {
            paginaActual = 1;
            renderizarGrilla();
        }

        // 4. Cargar la siguiente página
        function cargarMas() {
            paginaActual++;
            renderizarGrilla();
        }

        // 5. Renderizar la grilla con paginación
        function renderizarGrilla() {
            const grid = document.getElementById('grid-productos');
            const busqueda = document.getElementById('buscador').value.toLowerCase();
            const btnCargarMas = document.getElementById('btn-cargar-mas');
            
            // Si estamos en la página 1, limpiamos la grilla. Si no, agregamos al final.
            if (paginaActual === 1) {
                grid.innerHTML = '';
            }

            let productosFiltrados = inventarioGlobal;

            // Filtro por pestaña "Ofertas"
            if (pestanaActual === 'ofertas') {
                productosFiltrados = inventarioGlobal.filter(p => p.en_promo == 1 && parseFloat(p.descuento_promo) > 0);
            }

            // Filtro por buscador
            if (busqueda) {
                // Separamos los términos de búsqueda para encontrar coincidencias parciales
                const terminos = busqueda.split(' ');
                productosFiltrados = productosFiltrados.filter(p => {
                    const nombreNormalizado = p.nombre.toLowerCase();
                    return terminos.every(termino => nombreNormalizado.includes(termino));
                });
            }

            if (productosFiltrados.length === 0) {
                grid.innerHTML = '<p style="grid-column: 1/-1; text-align: center;">No se encontraron productos.</p>';
                btnCargarMas.style.display = 'none';
                return;
            }

            // Lógica de Paginación: Cortar el array según la página actual
            const inicio = (paginaActual - 1) * PRODUCTOS_POR_PAGINA;
            const fin = paginaActual * PRODUCTOS_POR_PAGINA;
            const productosAMostrar = productosFiltrados.slice(inicio, fin);

            // Generar las tarjetas
            productosAMostrar.forEach(p => {
                const isSelected = idsSeleccionados.includes(p.id_producto.trim());
                const card = document.createElement('div');
                card.className = `card ${isSelected ? 'selected' : ''}`;
                card.onclick = () => toggleSeleccion(p.id_producto.trim(), card);

                // Etiqueta visual si tiene oferta del ERP
                let badge = '';
                if (p.en_promo == 1 && parseFloat(p.descuento_promo) > 0) {
                    // Calculamos el % igual que en app.js
                    let desc = parseFloat(p.descuento_promo);
                    let porcentajeMostrar = desc <= 100 ? desc : Math.round((desc / p.precio_venta_final) * 100);
                    badge = `<div class="badge-promo">-${porcentajeMostrar}%</div>`;
                }

                card.innerHTML = `
                    ${badge}
                    <img src="https://api.surtitodoideal.com${p.proimagenurl}" onerror="this.src='https://api.surtitodoideal.com/static/images/no-image.png'">
                    <h3>${p.nombre.charAt(0).toUpperCase() + p.nombre.slice(1).toLowerCase()}</h3>
                    <div style="color: #E60000; font-weight: 800; font-size: 1.1rem;">$${Number(p.precio_venta_final).toLocaleString('es-CO')}</div>
                `;
                grid.appendChild(card);
            });

            // Mostrar u ocultar el botón "Cargar más"
            if (fin < productosFiltrados.length) {
                btnCargarMas.style.display = 'block';
            } else {
                btnCargarMas.style.display = 'none';
            }
        }

        // 6. Seleccionar/Deseleccionar producto
        function toggleSeleccion(id, cardElement) {
            const index = idsSeleccionados.indexOf(id);
            if (index === -1) {
                // CAMBIO AQUÍ: Usamos la variable en lugar del número estático
                if (idsSeleccionados.length >= limiteProductos) {
                    alert(`El formato seleccionado solo admite máximo ${limiteProductos} productos.`);
                    return;
                }
                idsSeleccionados.push(id);
                cardElement.classList.add('selected');
            } else {
                idsSeleccionados.splice(index, 1);
                cardElement.classList.remove('selected');
            }
            actualizarBotonFlotante();
        }

        function actualizarBotonFlotante() {
            const btn = document.getElementById('btn-generar');
            if (idsSeleccionados.length > 0) {
                btn.style.display = 'block';
                btn.innerText = `Generar Volante (${idsSeleccionados.length})`;
            } else {
                btn.style.display = 'none';
            }
        }

        // 7. Enviar al servidor para generar la foto
        async function generarVolante() {
            const btn = document.getElementById('btn-generar');
            const textoOriginal = btn.innerText;
            btn.innerText = '⏳ Diseñando...';
            btn.disabled = true;

            const plantilla = document.getElementById('selector-plantilla').value;
            const tema = document.getElementById('selector-tema').value;
            const orientacion = document.getElementById('selector-orientacion').value; // <-- NUEVO
            
            let tituloPrincipal = document.getElementById('selector-titulo').value;
            if (tituloPrincipal === 'PERSONALIZADO') {
                tituloPrincipal = document.getElementById('input-titulo-manual').value || 'Ofertas Surtitodo';
            }
            const textoTagline = document.getElementById('selector-tagline').value;

            try {
                const res = await fetch('/generar-volante', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    // <-- ENVIAMOS LA ORIENTACIÓN AL SERVIDOR
                    body: JSON.stringify({ idsSeleccionados, plantilla, tema, tituloPrincipal, textoTagline, orientacion }) 
                });

                if (!res.ok) throw new Error('Error en el servidor');

                const blob = await res.blob();
                const imageUrl = URL.createObjectURL(blob);
                
                document.getElementById('imagen-resultado').src = imageUrl;
                
                // Generar nombre de archivo con la fecha
                // Generar nombre dinámico con el tema y la fecha
                const temaSeleccionado = document.getElementById('selector-tema').options[document.getElementById('selector-tema').selectedIndex].text;
                const nombreLimpio = temaSeleccionado.replace(/[^a-zA-Z0-9]/g, '_').replace(/_+/g, '_'); // Quita emojis y espacios
                const fecha = new Date().toISOString().slice(0,10);

                document.getElementById('btn-descargar').download = `Volante_${nombreLimpio}_${fecha}.png`;
                document.getElementById('btn-descargar').href = imageUrl;
                
                generarTextoCopy(tituloPrincipal);
                
                document.getElementById('modal-resultado').style.display = 'flex';

            } catch (error) {
                alert('Hubo un error al generar el volante.');
            } finally {
                btn.innerText = textoOriginal;
                btn.disabled = false;
            }
        }

        // --- CREADOR AUTOMÁTICO DE COPY (TEXTO PARA REDES) ---
        function generarTextoCopy(titulo) {
            // Filtramos los productos que elegiste del inventario que ya descargó la web
            const productosElegidos = inventarioGlobal.filter(p => idsSeleccionados.includes(p.id_producto.trim()));
            
            let copy = `🚨 ¡${titulo} en Surtitodo Ideal! 🚨\n\n`;
            
            productosElegidos.forEach(p => {
                let nombreLimpio = p.nombre.charAt(0).toUpperCase() + p.nombre.slice(1).toLowerCase();
                let precioFormato = Number(p.precio_venta_final).toLocaleString('es-CO');
                copy += `✅ ${nombreLimpio} ➡️ por solo $${precioFormato}\n`;
            });
            
            copy += `\n🛒 Haz tu pedido sin salir de casa aquí:\n🌐 surtitodoideal.com\n\n`;
            copy += `📱 O escríbenos al WhatsApp: 312 840 6312\n\n`;
            copy += `#SurtitodoIdeal #Caicedonia #Ofertas #Supermercado #Ahorro #MercadoEnCasa`;
            
            document.getElementById('texto-copy').value = copy;
        }

        // --- BOTÓN PARA COPIAR PORTAPAPELES ---
        function copiarCopy() {
            const texto = document.getElementById("texto-copy");
            texto.select();
            document.execCommand("copy");
            alert("✅ ¡Texto copiado! Ya puedes pegarlo en Instagram o Facebook.");
        }

        function cerrarModal() {
            document.getElementById('modal-resultado').style.display = 'none';
        }

        let limiteProductos = 4; // Por defecto es 4

        // 1. Función que se dispara al cambiar el menú desplegable
        function cambiarLimitePlantilla() {
            limiteProductos = parseInt(document.getElementById('selector-plantilla').value);
            
            // Si el usuario tenía seleccionados 4 y cambia a plantilla de 2, borramos los que sobran
            if (idsSeleccionados.length > limiteProductos) {
                idsSeleccionados = idsSeleccionados.slice(0, limiteProductos);
                renderizarGrilla(); // Refrescamos visualmente
                actualizarBotonFlotante();
            }
        }

        // --- NUEVA FUNCIÓN PARA EL TÍTULO MANUAL ---
        function verificarTituloManual() {
            const selector = document.getElementById('selector-titulo');
            const inputManual = document.getElementById('input-titulo-manual');
            if (selector.value === 'PERSONALIZADO') {
                inputManual.style.display = 'block';
                inputManual.focus();
            } else {
                inputManual.style.display = 'none';
            }
        }

        // --- FUNCIÓN PARA ORDENAR LA CREACIÓN DEL VIDEO ---
        async function generarVideoRemotion() {
            if (idsSeleccionados.length === 0) {
                alert("¡Selecciona al menos un producto para el video!");
                return;
            }

            // Mostramos el mensaje de carga
            document.getElementById('cargando-video').style.display = 'block';

            try {
                const res = await fetch('/generar-video', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ idsSeleccionados })
                });

                if (res.ok) {
                    const data = await res.json();
                    
                    // Ocultamos el mensaje de carga
                    document.getElementById('cargando-video').style.display = 'none';
                    
                    // Abrimos el video en una nueva pestaña o disparamos la descarga
                    window.open(data.urlVideo, '_blank');
                } else {
                    alert("Hubo un error al generar el video. Revisa la consola del servidor.");
                    document.getElementById('cargando-video').style.display = 'none';
                }
            } catch (error) {
                console.error(error);
                alert("Error de conexión con el servidor.");
                document.getElementById('cargando-video').style.display = 'none';
            }
        }

        cargarDatos();
    </script>
</body>
</html>